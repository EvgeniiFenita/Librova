<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════
       WARM LIBRARY PALETTE
       Base: near-black warm sepia → Amber/gold accent
       ═══════════════════════════════════════════════ -->

  <!-- Backgrounds — layered from darkest to lightest -->
  <Color x:Key="Color.Background">#0D0A07</Color>
  <Color x:Key="Color.BackgroundElevated">#110D09</Color>
  <Color x:Key="Color.Sidebar">#100C08</Color>
  <Color x:Key="Color.Surface">#161108</Color>
  <Color x:Key="Color.SurfaceMuted">#1C160C</Color>
  <Color x:Key="Color.SurfaceAlt">#221A0E</Color>
  <Color x:Key="Color.SurfaceHover">#2A2012</Color>

  <!-- Borders -->
  <Color x:Key="Color.Border">#2A200E</Color>
  <Color x:Key="Color.BorderStrong">#3A2E18</Color>
  <Color x:Key="Color.SidebarBorder">#211A0C</Color>

  <!-- Accent — amber / gold -->
  <Color x:Key="Color.Accent">#F5A623</Color>
  <Color x:Key="Color.AccentBright">#FFD07A</Color>
  <Color x:Key="Color.AccentDim">#B87A1A</Color>
  <Color x:Key="Color.AccentMuted">#2A1C06</Color>
  <Color x:Key="Color.AccentSurface">#1A1003</Color>
  <Color x:Key="Color.AccentBorder">#3D2C0A</Color>

  <!-- Status — success -->
  <Color x:Key="Color.SuccessSurface">#08221A</Color>
  <Color x:Key="Color.SuccessBorder">#124E37</Color>
  <Color x:Key="Color.Success">#34D39A</Color>

  <!-- Status — warning -->
  <Color x:Key="Color.Warning">#F9BF4C</Color>
  <Color x:Key="Color.WarningSurface">#221806</Color>

  <!-- Status — danger -->
  <Color x:Key="Color.Danger">#F87171</Color>
  <Color x:Key="Color.DangerSurface">#200A0C</Color>
  <Color x:Key="Color.DangerBorder">#551820</Color>

  <!-- Text hierarchy -->
  <Color x:Key="Color.TextPrimary">#F5EDD8</Color>
  <Color x:Key="Color.TextSecondary">#A89880</Color>
  <Color x:Key="Color.TextMuted">#967E68</Color>

  <!-- Cover matte (book cover placeholder bg) -->
  <Color x:Key="Color.Matte">#0A0700</Color>

  <!-- Cover placeholder initials text -->
  <Color x:Key="Color.CoverPlaceholder">#F5EDD8</Color>

  <!-- Text on filled accent (PrimaryAction) button -->
  <Color x:Key="Color.OnAccent">#0A0700</Color>

  <!-- Danger button text colours -->
  <Color x:Key="Color.DangerText">#FFDDDD</Color>
  <Color x:Key="Color.DangerTextHover">#FFE8E8</Color>
  <Color x:Key="Color.DangerHoverBg">#3D0E12</Color>

  <!-- Nav sidebar active item -->
  <Color x:Key="Color.NavActive">#1E1606</Color>
  <Color x:Key="Color.NavActiveHover">#261C08</Color>

  <!-- Glow / overlay colours derived from accent — cannot be expressed as
       DynamicResource inside BoxShadow strings (Avalonia limitation), so
       they are declared here as named tokens. Update alongside Color.Accent
       when changing the palette.
         AccentGlow     = Accent at ~22% opacity  (book card hover shadow)
         AccentSelection= Accent at ~25% opacity  (text selection highlight) -->
  <Color x:Key="Color.AccentGlow">#38F5A623</Color>
  <Color x:Key="Color.AccentSelection">#40F5A623</Color>

  <!-- ═══════════════ BRUSHES ═══════════════ -->

  <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource Color.Background}" />
  <SolidColorBrush x:Key="AppBackgroundElevatedBrush" Color="{StaticResource Color.BackgroundElevated}" />
  <SolidColorBrush x:Key="AppSidebarBrush" Color="{StaticResource Color.Sidebar}" />
  <!-- Sidebar vertical gradient: recessed/shadowed at top, warm amber undertone at base.
       GradientStop Colors reference Color.* tokens by value (Avalonia limitation — Color tokens
       cannot be used inside GradientStop.Color via StaticResource in LinearGradientBrush).
       Update alongside Color.Sidebar / Color.Background when changing the palette. -->
  <LinearGradientBrush x:Key="AppSidebarGradientBrush" StartPoint="0%,0%" EndPoint="0%,100%">
    <GradientStop Offset="0"   Color="#0A0806" />
    <GradientStop Offset="1"   Color="#1A1409" />
  </LinearGradientBrush>
  <SolidColorBrush x:Key="AppSidebarBorderBrush" Color="{StaticResource Color.SidebarBorder}" />
  <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource Color.Surface}" />
  <SolidColorBrush x:Key="AppSurfaceMutedBrush" Color="{StaticResource Color.SurfaceMuted}" />
  <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="{StaticResource Color.SurfaceAlt}" />
  <SolidColorBrush x:Key="AppSurfaceHoverBrush" Color="{StaticResource Color.SurfaceHover}" />
  <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource Color.Border}" />
  <SolidColorBrush x:Key="AppBorderStrongBrush" Color="{StaticResource Color.BorderStrong}" />
  <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="AppAccentBrightBrush" Color="{StaticResource Color.AccentBright}" />
  <SolidColorBrush x:Key="AppAccentDimBrush" Color="{StaticResource Color.AccentDim}" />
  <SolidColorBrush x:Key="AppAccentMutedBrush" Color="{StaticResource Color.AccentMuted}" />
  <SolidColorBrush x:Key="AppAccentSurfaceBrush" Color="{StaticResource Color.AccentSurface}" />
  <SolidColorBrush x:Key="AppAccentBorderBrush" Color="{StaticResource Color.AccentBorder}" />
  <SolidColorBrush x:Key="AppSuccessSurfaceBrush" Color="{StaticResource Color.SuccessSurface}" />
  <SolidColorBrush x:Key="AppSuccessBorderBrush" Color="{StaticResource Color.SuccessBorder}" />
  <SolidColorBrush x:Key="AppSuccessBrush" Color="{StaticResource Color.Success}" />
  <SolidColorBrush x:Key="AppWarningBrush" Color="{StaticResource Color.Warning}" />
  <SolidColorBrush x:Key="AppWarningSurfaceBrush" Color="{StaticResource Color.WarningSurface}" />
  <SolidColorBrush x:Key="AppDangerBrush" Color="{StaticResource Color.Danger}" />
  <SolidColorBrush x:Key="AppDangerSurfaceBrush" Color="{StaticResource Color.DangerSurface}" />
  <SolidColorBrush x:Key="AppDangerBorderBrush" Color="{StaticResource Color.DangerBorder}" />
  <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{StaticResource Color.TextSecondary}" />
  <SolidColorBrush x:Key="AppTextMutedBrush" Color="{StaticResource Color.TextMuted}" />
  <SolidColorBrush x:Key="AppMatteBrush"          Color="{StaticResource Color.Matte}" />
  <SolidColorBrush x:Key="AppCoverPlaceholderBrush" Color="{StaticResource Color.CoverPlaceholder}" />
  <SolidColorBrush x:Key="AppOnAccentBrush"        Color="{StaticResource Color.OnAccent}" />
  <SolidColorBrush x:Key="AppDangerTextBrush"       Color="{StaticResource Color.DangerText}" />
  <SolidColorBrush x:Key="AppDangerTextHoverBrush"  Color="{StaticResource Color.DangerTextHover}" />
  <SolidColorBrush x:Key="AppDangerHoverBgBrush"    Color="{StaticResource Color.DangerHoverBg}" />
  <SolidColorBrush x:Key="AppNavActiveBrush"        Color="{StaticResource Color.NavActive}" />
  <SolidColorBrush x:Key="AppNavActiveHoverBrush"   Color="{StaticResource Color.NavActiveHover}" />

  <!-- ═══════════════ LAYOUT TOKENS ═══════════════ -->

  <CornerRadius x:Key="Radius.Small">8</CornerRadius>
  <CornerRadius x:Key="Radius.Medium">12</CornerRadius>
  <CornerRadius x:Key="Radius.Large">18</CornerRadius>
  <CornerRadius x:Key="Radius.XLarge">24</CornerRadius>
  <Thickness x:Key="Padding.Card">22</Thickness>
  <Thickness x:Key="Padding.CardCompact">16</Thickness>
  <Thickness x:Key="Padding.Sidebar">16,20</Thickness>

  <!-- ═══════════════ FLUENT TEXTBOX RESOURCE OVERRIDES ════════════════
       Override the DynamicResource keys consumed by FluentTheme's TextBox
       ControlTheme. Without these, Avalonia falls back to system accent
       (blue) for the focus border and system gray for the background.
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Background states -->
  <SolidColorBrush x:Key="TextControlBackground"                Color="{StaticResource Color.SurfaceAlt}" />
  <SolidColorBrush x:Key="TextControlBackgroundPointerOver"     Color="{StaticResource Color.SurfaceHover}" />
  <SolidColorBrush x:Key="TextControlBackgroundFocused"         Color="{StaticResource Color.SurfaceAlt}" />
  <SolidColorBrush x:Key="TextControlBackgroundDisabled"        Color="{StaticResource Color.SurfaceMuted}" />

  <!-- Border states — focused uses amber accent instead of system blue -->
  <SolidColorBrush x:Key="TextControlBorderBrush"               Color="{StaticResource Color.Border}" />
  <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"    Color="{StaticResource Color.BorderStrong}" />
  <SolidColorBrush x:Key="TextControlBorderBrushFocused"        Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="TextControlBorderBrushDisabled"       Color="{StaticResource Color.Border}" />

  <!-- Text & placeholder -->
  <SolidColorBrush x:Key="TextControlForeground"                              Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="TextControlForegroundPointerOver"                   Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="TextControlForegroundFocused"                       Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="TextControlForegroundDisabled"                      Color="{StaticResource Color.TextMuted}" />
  <SolidColorBrush x:Key="TextControlPlaceholderForeground"                   Color="{StaticResource Color.TextMuted}" />
  <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver"        Color="{StaticResource Color.TextMuted}" />
  <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused"            Color="{StaticResource Color.TextMuted}" />
  <SolidColorBrush x:Key="TextControlPlaceholderForegroundDisabled"           Color="{StaticResource Color.TextMuted}" />

  <!-- Selection highlight — Accent at ~25% opacity.
       Color resources cannot reference other Color resources via StaticResource
       in Avalonia (not supported inside <Color> text content). Value manually
       mirrors Color.Accent (#F5A623) at 0x40 alpha. Update together. -->
  <Color x:Key="TextControlSelectionHighlightColor">#40F5A623</Color>

  <!-- ═══════════════ FLUENT CHECKBOX RESOURCE OVERRIDES ════════════════
       Override the DynamicResource keys consumed by FluentTheme's CheckBox
       ControlTheme. Without these the checkmark and fill stay system-blue.
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Checked fill and border -->
  <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked"             Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver"  Color="{StaticResource Color.AccentBright}" />
  <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed"      Color="{StaticResource Color.AccentDim}" />
  <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked"           Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPointerOver" Color="{StaticResource Color.AccentBright}" />
  <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPressed"    Color="{StaticResource Color.AccentDim}" />

  <!-- Unchecked border -->
  <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUnchecked"         Color="{StaticResource Color.BorderStrong}" />
  <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeUncheckedPointerOver" Color="{StaticResource Color.Accent}" />

  <!-- Checkmark glyph colour (on top of filled background) -->
  <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundChecked"            Color="{StaticResource Color.OnAccent}" />
  <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPointerOver" Color="{StaticResource Color.OnAccent}" />
  <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundCheckedPressed"     Color="{StaticResource Color.OnAccent}" />

  <!-- ═══════════════ FLUENT COMBOBOX RESOURCE OVERRIDES ════════════════
       Override the DynamicResource keys consumed by FluentTheme's ComboBox
       ControlTheme. Without these, hover/pressed states fall back to black
       background and white border from the Fluent dark-mode defaults.
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Background states -->
  <SolidColorBrush x:Key="ComboBoxBackground"                  Color="{StaticResource Color.SurfaceAlt}" />
  <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver"       Color="{StaticResource Color.SurfaceHover}" />
  <SolidColorBrush x:Key="ComboBoxBackgroundPressed"           Color="{StaticResource Color.SurfaceHover}" />
  <SolidColorBrush x:Key="ComboBoxBackgroundFocused"           Color="{StaticResource Color.SurfaceAlt}" />
  <SolidColorBrush x:Key="ComboBoxBackgroundDisabled"          Color="{StaticResource Color.SurfaceMuted}" />

  <!-- Border states -->
  <SolidColorBrush x:Key="ComboBoxBorderBrush"                 Color="{StaticResource Color.Border}" />
  <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver"      Color="{StaticResource Color.BorderStrong}" />
  <SolidColorBrush x:Key="ComboBoxBorderBrushPressed"          Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="ComboBoxBorderBrushFocused"          Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="ComboBoxBorderBrushDisabled"         Color="{StaticResource Color.Border}" />

  <!-- Foreground states -->
  <SolidColorBrush x:Key="ComboBoxForeground"                  Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="ComboBoxForegroundPointerOver"       Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="ComboBoxForegroundFocused"           Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="ComboBoxForegroundDisabled"          Color="{StaticResource Color.TextMuted}" />

  <!-- Dropdown popup surface -->
  <SolidColorBrush x:Key="ComboBoxDropDownBackground"          Color="{StaticResource Color.SurfaceMuted}" />
  <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush"         Color="{StaticResource Color.Border}" />
  <SolidColorBrush x:Key="ComboBoxDropDownGlyphForeground"     Color="{StaticResource Color.TextSecondary}" />

  <!-- ═══════════════ FLUENT SCROLLBAR RESOURCE OVERRIDES ═══════════════
       Override the DynamicResource keys used by FluentScrollBarThumb,
       FluentScrollBarLineButton, and the ScrollBar ControlTheme so that
       all scrollbar states match the app's warm sepia palette.
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- Scrollbar strip itself: always transparent -->
  <SolidColorBrush x:Key="ScrollBarBackground"              Color="Transparent" />
  <SolidColorBrush x:Key="ScrollBarBorderBrush"             Color="Transparent" />
  <SolidColorBrush x:Key="ScrollBarForeground"              Color="Transparent" />

  <!-- Track rectangle (fills behind the thumb when expanded) -->
  <SolidColorBrush x:Key="ScrollBarTrackFill"               Color="Transparent" />
  <SolidColorBrush x:Key="ScrollBarTrackStroke"             Color="Transparent" />
  <SolidColorBrush x:Key="ScrollBarBackgroundPointerOver"   Color="Transparent" />
  <SolidColorBrush x:Key="ScrollBarTrackFillPointerOver"    Color="{StaticResource Color.SurfaceMuted}" />
  <SolidColorBrush x:Key="ScrollBarTrackStrokePointerOver"  Color="{StaticResource Color.Border}" />

  <!-- Thumb — collapsed (panning) state and expanded state use different keys -->
  <SolidColorBrush x:Key="ScrollBarPanningThumbBackground"  Color="{StaticResource Color.BorderStrong}" />
  <SolidColorBrush x:Key="ScrollBarThumbBackgroundColor"    Color="{StaticResource Color.BorderStrong}" />
  <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver"    Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="ScrollBarThumbFillPressed"        Color="{StaticResource Color.AccentDim}" />
  <SolidColorBrush x:Key="ScrollBarThumbFillDisabled"       Color="{StaticResource Color.Border}" />

  <!-- Arrow line-buttons -->
  <SolidColorBrush x:Key="ScrollBarButtonBackground"                  Color="Transparent" />
  <SolidColorBrush x:Key="ScrollBarButtonBorderBrush"                 Color="Transparent" />
  <SolidColorBrush x:Key="ScrollBarButtonArrowForeground"             Color="{StaticResource Color.TextMuted}" />
  <SolidColorBrush x:Key="ScrollBarButtonBackgroundPointerOver"       Color="{StaticResource Color.SurfaceAlt}" />
  <SolidColorBrush x:Key="ScrollBarButtonBorderBrushPointerOver"      Color="{StaticResource Color.Border}" />
  <SolidColorBrush x:Key="ScrollBarButtonArrowForegroundPointerOver"  Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="ScrollBarButtonBackgroundPressed"           Color="{StaticResource Color.AccentMuted}" />
  <SolidColorBrush x:Key="ScrollBarButtonBorderBrushPressed"          Color="{StaticResource Color.AccentBorder}" />
  <SolidColorBrush x:Key="ScrollBarButtonArrowForegroundPressed"      Color="{StaticResource Color.Accent}" />
  <SolidColorBrush x:Key="ScrollBarButtonBackgroundDisabled"          Color="Transparent" />
  <SolidColorBrush x:Key="ScrollBarButtonBorderBrushDisabled"         Color="Transparent" />
  <SolidColorBrush x:Key="ScrollBarButtonArrowForegroundDisabled"     Color="{StaticResource Color.Border}" />

  <!-- ═══════════════ ICONS ═══════════════ -->

  <!-- Books on a shelf — Library nav item -->
  <StreamGeometry x:Key="IconLibrary">M3,21 L21,21 L21,23 L3,23 Z M4,5 L8,5 L8,21 L4,21 Z M10,7 L15,7 L15,21 L10,21 Z M17,9 L20,9 L20,21 L17,21 Z</StreamGeometry>

  <!-- Bookmark silhouette — sidebar brand identity (reads clearly as solid fill at any size) -->
  <StreamGeometry x:Key="IconBook">M6,2 L18,2 L18,22 L12,17 L6,22 Z</StreamGeometry>

  <!-- Arrow pointing DOWN into tray = bringing files INTO the library (import) -->
  <StreamGeometry x:Key="IconImport">M12,16 L17,11 L14,11 L14,5 L10,5 L10,11 L7,11 Z M5,17 L19,17 L19,20 L5,20 Z</StreamGeometry>

  <!-- Gear (Settings nav) -->
  <StreamGeometry x:Key="IconSettings">M9.5,3 L14.5,3 L15.1,5.2 C15.57,5.38 16.02,5.62 16.43,5.91 L18.56,5.15 L21.05,9.46 L19.26,10.84 C19.3,11.22 19.3,11.6 19.26,11.98 L21.05,13.36 L18.56,17.67 L16.43,16.91 C16.02,17.2 15.57,17.44 15.1,17.62 L14.5,19.84 L9.5,19.84 L8.9,17.62 C8.43,17.44 7.98,17.2 7.57,16.91 L5.44,17.67 L2.95,13.36 L4.74,11.98 C4.7,11.6 4.7,11.22 4.74,10.84 L2.95,9.46 L5.44,5.15 L7.57,5.91 C7.98,5.62 8.43,5.38 8.9,5.2 Z M12,8.5 C10.07,8.5 8.5,10.07 8.5,12 C8.5,13.93 10.07,15.5 12,15.5 C13.93,15.5 15.5,13.93 15.5,12 C15.5,10.07 13.93,8.5 12,8.5 Z</StreamGeometry>

  <!-- Open folder -->
  <StreamGeometry x:Key="IconFolderOpen">M3,6 C3,4.895 3.895,4 5,4 L9,4 L11,6 L19,6 C20.105,6 21,6.895 21,8 L21,17 C21,18.105 20.105,19 19,19 L5,19 C3.895,19 3,18.105 3,17 Z M6,9 L18,9 L16.4,16 L4.6,16 Z</StreamGeometry>

  <!-- Folder + plus -->
  <StreamGeometry x:Key="IconAddFolder">M3,6 C3,4.895 3.895,4 5,4 L9,4 L11,6 L19,6 C20.105,6 21,6.895 21,8 L21,17 C21,18.105 20.105,19 19,19 L5,19 C3.895,19 3,18.105 3,17 Z M12,9 L12,11.5 L14.5,11.5 L14.5,13.5 L12,13.5 L12,16 L10,16 L10,13.5 L7.5,13.5 L7.5,11.5 L10,11.5 L10,9 Z</StreamGeometry>

  <!-- Search magnifier -->
  <StreamGeometry x:Key="IconSearch">M10.5,4 C14.09,4 17,6.91 17,10.5 C17,12.03 16.47,13.43 15.59,14.53 L20,18.94 L18.94,20 L14.53,15.59 C13.43,16.47 12.03,17 10.5,17 C6.91,17 4,14.09 4,10.5 C4,6.91 6.91,4 10.5,4 Z M10.5,6 C8.01,6 6,8.01 6,10.5 C6,12.99 8.01,15 10.5,15 C12.99,15 15,12.99 15,10.5 C15,8.01 12.99,6 10.5,6 Z</StreamGeometry>

  <!-- × close -->
  <StreamGeometry x:Key="IconClose">M6.4,5 L12,10.6 L17.6,5 L19,6.4 L13.4,12 L19,17.6 L17.6,19 L12,13.4 L6.4,19 L5,17.6 L10.6,12 L5,6.4 Z</StreamGeometry>

  <!-- Arrow-up from tray (Export) -->
  <StreamGeometry x:Key="IconExport">M12,4 L16,8 L13,8 L13,14 L11,14 L11,8 L8,8 Z M5,16 L19,16 L19,19 L5,19 Z</StreamGeometry>

  <!-- Trash can -->
  <StreamGeometry x:Key="IconTrash">M9,4 L15,4 L16,6 L20,6 L20,8 L4,8 L4,6 L8,6 Z M6,9 L18,9 L17,20 L7,20 Z M9,11 L9,18 L11,18 L11,11 Z M13,11 L13,18 L15,18 L15,11 Z</StreamGeometry>

  <!-- Info circle -->
  <StreamGeometry x:Key="IconInfo">M12,3.5 C16.69,3.5 20.5,7.31 20.5,12 C20.5,16.69 16.69,20.5 12,20.5 C7.31,20.5 3.5,16.69 3.5,12 C3.5,7.31 7.31,3.5 12,3.5 Z M11,10 L11,17 L13,17 L13,10 Z M11,7 L11,9 L13,9 L13,7 Z</StreamGeometry>

  <!-- Chevron right (kept for compatibility) -->
  <StreamGeometry x:Key="IconChevronRight">M8,5 L15,12 L8,19 L6.6,17.6 L12.2,12 L6.6,6.4 Z</StreamGeometry>

  <!-- Cloud / drop zone (Import drop area) -->
  <StreamGeometry x:Key="IconUploadCloud">M12,3 C15.87,3 19,5.92 19.46,9.68 C21.45,10.17 23,12.0 23,14.2 C23,16.85 20.85,19 18.2,19 L14,19 L14,13.41 L15.59,15 L17,13.59 L12,8.59 L7,13.59 L8.41,15 L10,13.41 L10,19 L5.8,19 C3.15,19 1,16.85 1,14.2 C1,12.0 2.55,10.17 4.54,9.68 C5,5.92 8.13,3 12,3 Z</StreamGeometry>

  <!-- Warning triangle with exclamation mark — validation errors, startup warnings -->
  <StreamGeometry x:Key="IconWarning">M12,2 L22,20 L2,20 Z M11,9 L11,14 L13,14 L13,9 Z M11,16 L11,18 L13,18 L13,16 Z</StreamGeometry>

  <!-- Check circle — import success, operation complete -->
  <StreamGeometry x:Key="IconCheck">M12,3.5 C16.69,3.5 20.5,7.31 20.5,12 C20.5,16.69 16.69,20.5 12,20.5 C7.31,20.5 3.5,16.69 3.5,12 C3.5,7.31 7.31,3.5 12,3.5 Z M7.5,12 L10.5,15 L16.5,9</StreamGeometry>

  <!-- Refresh / retry circular arrow — retry on startup error -->
  <StreamGeometry x:Key="IconRefresh">M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4.01,7.58 4.01,12 C4.01,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.83,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 Z</StreamGeometry>

</ResourceDictionary>
