<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ════════════════════════════════════════════
       WINDOW / SHELL
       ════════════════════════════════════════════ -->

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif" />
  </Style>

  <!-- Global tooltip — warm palette surface with cream text -->
  <Style Selector="ToolTip">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Small}" />
    <Setter Property="Padding" Value="8,5" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Unified shell card (sidebar + content as one surface) -->
  <Style Selector="Border.AppShell">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.XLarge}" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <!-- Sidebar background fill (no corner radius — clipped by parent AppShell) -->
  <Style Selector="Border.AppSidebarFill">
    <Setter Property="Background" Value="{DynamicResource AppSidebarBrush}" />
  </Style>

  <!-- ════════════════════════════════════════════
       SURFACE PANELS
       ════════════════════════════════════════════ -->

  <Style Selector="Border.AppPanel">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.XLarge}" />
    <Setter Property="Padding" Value="{DynamicResource Padding.Card}" />
  </Style>

  <Style Selector="Border.AppPanelCompact">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
    <Setter Property="Padding" Value="{DynamicResource Padding.CardCompact}" />
  </Style>

  <Style Selector="Border.AppPanelMuted">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Padding" Value="{DynamicResource Padding.CardCompact}" />
  </Style>

  <Style Selector="Border.AccentPanel">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
    <Setter Property="Padding" Value="{DynamicResource Padding.CardCompact}" />
  </Style>

  <Style Selector="Border.SuccessPanel">
    <Setter Property="Background" Value="{DynamicResource AppSuccessSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppSuccessBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
    <Setter Property="Padding" Value="{DynamicResource Padding.CardCompact}" />
  </Style>

  <Style Selector="Border.DangerPanel">
    <Setter Property="Background" Value="{DynamicResource AppDangerSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppDangerBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
    <Setter Property="Padding" Value="{DynamicResource Padding.Card}" />
  </Style>

  <!-- Import drop-zone: large dashed accent border -->
  <Style Selector="Border.DropZone">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
    <Setter Property="Padding" Value="32,40" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.15" />
        <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Border.DropZone.DragOver">
    <Setter Property="Background" Value="{DynamicResource AppAccentMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="Border.DropZone:disabled">
    <Setter Property="Opacity" Value="0.45" />
  </Style>

  <!-- ════════════════════════════════════════════
       BUTTONS
       ════════════════════════════════════════════ -->

  <Style Selector="Button">
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>

  <!-- ════════════════════════════════════════════
       GLOBAL DISABLED OPACITY
       Dims non-button interactive controls uniformly during import lock-out.
       Buttons have their own explicit :disabled ContentPresenter colour rules.
       ════════════════════════════════════════════ -->

  <Style Selector="TextBox:disabled">
    <Setter Property="Opacity" Value="0.38" />
  </Style>
  <Style Selector="ComboBox:disabled">
    <Setter Property="Opacity" Value="0.38" />
  </Style>
  <Style Selector="CheckBox:disabled">
    <Setter Property="Opacity" Value="0.38" />
  </Style>
  <Style Selector="Border.AppPanelMuted:disabled">
    <Setter Property="Opacity" Value="0.45" />
  </Style>

  <!--
    Lockout — generic lock-out state for shell regions during long-running jobs.
    Apply Classes.Lockout="{Binding ...}" to any container that should be
    disabled and dimmed as a unit. Adding a new long-running job type only
    requires binding the property; no per-widget wiring is needed.
  -->
  <Style Selector=":is(Control).Lockout">
    <Setter Property="IsEnabled" Value="False" />
    <Setter Property="Opacity" Value="0.4" />
  </Style>
  <!-- NavItem buttons carry their own :disabled opacity; suppress the
       extra multiplier when the entire parent region is already Lockout-dimmed. -->
  <Style Selector=":is(Control).Lockout Button.NavItem:disabled">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <!-- Primary (accent-filled) -->
  <Style Selector="Button.PrimaryAction">
    <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="Padding" Value="20,0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
  </Style>
  <Style Selector="Button.PrimaryAction /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}" />
  </Style>
  <Style Selector="Button.PrimaryAction:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentBrightBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppOnAccentBrush}" />
  </Style>
  <Style Selector="Button.PrimaryAction:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <!-- Secondary (subtle border) -->
  <Style Selector="Button.SecondaryAction">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="Padding" Value="18,0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
  </Style>
  <Style Selector="Button.SecondaryAction /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="Button.SecondaryAction:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="Button.SecondaryAction:disabled">
    <Setter Property="Opacity" Value="0.4" />
  </Style>
  <Style Selector="Button.SecondaryAction:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
  </Style>

  <!-- Accent-tinted action (export EPUB etc.) -->
  <Style Selector="Button.AccentAction">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="Padding" Value="18,0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
  </Style>
  <Style Selector="Button.AccentAction /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="Button.AccentAction:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrightBrush}" />
  </Style>
  <Style Selector="Button.AccentAction:disabled">
    <Setter Property="Opacity" Value="0.4" />
  </Style>
  <Style Selector="Button.AccentAction:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
  </Style>

  <!-- Destructive (delete / trash) -->
  <Style Selector="Button.DestructiveAction">
    <Setter Property="Background" Value="{DynamicResource AppDangerSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppDangerTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppDangerBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="Padding" Value="18,0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
  </Style>
  <Style Selector="Button.DestructiveAction /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppDangerSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppDangerTextBrush}" />
  </Style>
  <Style Selector="Button.DestructiveAction:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppDangerHoverBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppDangerTextHoverBrush}" />
  </Style>
  <Style Selector="Button.DestructiveAction:disabled">
    <Setter Property="Opacity" Value="0.4" />
  </Style>
  <Style Selector="Button.DestructiveAction:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppDangerSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
  </Style>

  <!-- Icon-only square button -->
  <Style Selector="Button.IconAction">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Small}" />
  </Style>
  <Style Selector="Button.IconAction /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
  </Style>
  <Style Selector="Button.IconAction:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="Button.IconAction:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppBorderBrush}" />
  </Style>

  <!-- Sidebar navigation item -->
  <Style Selector="Button.NavItem">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Small}" />
  </Style>
  <Style Selector="Button.NavItem /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
  </Style>
  <Style Selector="Button.NavItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
  </Style>
  <Style Selector="Button.NavItem.Active">
    <Setter Property="Background" Value="{DynamicResource AppNavActiveBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="Button.NavItem.Active /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppNavActiveBrush}" />
  </Style>
  <Style Selector="Button.NavItem.Active:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppNavActiveHoverBrush}" />
  </Style>
  <Style Selector="Button.NavItem:disabled">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="Button.NavItem:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
  </Style>

  <!-- Nav label text: dim when idle, bright white when active.
       Selector uses the PARENT button's Active class. -->

  <!-- ════════════════════════════════════════════
       OPTION CARDS  (binary / small-set mode selector)
       Two equal cards side-by-side; the active one gets an
       accent border + accent-tint background.
       ════════════════════════════════════════════ -->

  <Style Selector="Button.OptionCard">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Padding" Value="14" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Top" />
  </Style>
  <Style Selector="Button.OptionCard /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
  </Style>
  <Style Selector="Button.OptionCard:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
  </Style>
  <Style Selector="Button.OptionCard PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
  </Style>
  <Style Selector="Button.OptionCard TextBlock.OptionCardTitle">
    <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.OptionCard.Active">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="Button.OptionCard.Active /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
  </Style>
  <Style Selector="Button.OptionCard.Active:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
  </Style>
  <Style Selector="Button.OptionCard.Active PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="Button.OptionCard.Active TextBlock.OptionCardTitle">
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>

  <Style Selector="Button.OptionCard:disabled">
    <Setter Property="Opacity" Value="0.45" />
  </Style>
  <Style Selector="Button.OptionCard:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
  </Style>

  <!-- ════════════════════════════════════════════
       TEXT INPUTS
       ════════════════════════════════════════════ -->

  <Style Selector="TextBox.AppTextInput">
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Padding" Value="14,0" />
  </Style>

  <Style Selector="TextBox.AppTextArea">
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14,12" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <!-- ════════════════════════════════════════════
       COMBOBOX
       ════════════════════════════════════════════ -->

  <Style Selector="ComboBox.AppComboBox">
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
  </Style>
  <Style Selector="ComboBox.AppComboBox:pointerover">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
  </Style>
  <Style Selector="ComboBox.AppComboBox /template/ ToggleButton">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
  </Style>
  <Style Selector="ComboBox.AppComboBox:pointerover /template/ ToggleButton">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
  </Style>
  <Style Selector="ComboBox.AppComboBox:pointerover /template/ ToggleButton /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
  </Style>
  <Style Selector="ComboBox.AppComboBox /template/ ToggleButton:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
  </Style>
  <Style Selector="ComboBox.AppComboBox:focus /template/ ToggleButton">
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="ComboBox.AppComboBox /template/ ContentPresenter">
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="ComboBoxItem">
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ComboBoxItem /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <!-- Selected: accent tint, styled via ContentPresenter to override Fluent default gray -->
  <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrightBrush}" />
  </Style>
  <!-- Popup container background — overrides the Fluent gray popup surface -->
  <Style Selector="ComboBox.AppComboBox /template/ Border#PopupBorder">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceElevatedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
  </Style>
  <!-- Gap between ComboBox button and its dropdown list -->
  <Style Selector="ComboBox.AppComboBox /template/ Popup#PART_Popup">
    <Setter Property="VerticalOffset" Value="6" />
  </Style>
  <!-- Dropdown chevron turns accent when the list is open -->
  <Style Selector="ComboBox.AppComboBox:dropdownopen /template/ PathIcon#DropDownGlyph">
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
  </Style>

  <!-- ════════════════════════════════════════════
       CHECKBOX
       ════════════════════════════════════════════ -->

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="CheckBox:pointerover /template/ ContentPresenter">
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>

  <!-- ════════════════════════════════════════════
       BADGES / PILLS
       ════════════════════════════════════════════ -->

  <Style Selector="Border.MetricPill">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Padding" Value="14,8" />
  </Style>

  <!-- Accent-tinted book count stat pill -->
  <Style Selector="Border.MetricPillAccent">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Padding" Value="14,8" />
  </Style>

  <!-- ════════════════════════════════════════════
       SORT GROUP (unified key + direction capsule)
       ════════════════════════════════════════════ -->

  <!-- Outer pill — clips children so hover fills match the rounded shape -->
  <Style Selector="Border.SortGroup">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <!-- ComboBox inside SortGroup: merge into shared surface (no own border/bg) -->
  <Style Selector="Border.SortGroup ComboBox.AppComboBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>
  <Style Selector="Border.SortGroup ComboBox.AppComboBox /template/ ToggleButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>
  <Style Selector="Border.SortGroup ComboBox.AppComboBox:pointerover /template/ ToggleButton">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>
  <Style Selector="Border.SortGroup ComboBox.AppComboBox /template/ ToggleButton:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
  </Style>

  <!-- IconAction button inside SortGroup: flush ghost, left border = separator -->
  <Style Selector="Border.SortGroup Button.IconAction">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1,0,0,0" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Width" Value="42" />
    <Setter Property="Height" Value="42" />
  </Style>
  <Style Selector="Border.SortGroup Button.IconAction /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
  </Style>
  <Style Selector="Border.SortGroup Button.IconAction:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>

  <!-- ════════════════════════════════════════════
       BOOK COVER MATTE
       ════════════════════════════════════════════ -->

  <Style Selector="Border.CoverMatte">
    <Setter Property="Background" Value="{DynamicResource AppMatteBrush}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="BoxShadow" Value="0 6 20 0 #40000000" />
  </Style>

  <!-- ════════════════════════════════════════════
       SCROLLBAR
       ════════════════════════════════════════════ -->

  <!-- All colours are driven by the FluentTheme resource-key overrides in Colors.axaml.
       Only CornerRadius needs a style override because FluentScrollBarThumb uses
       {TemplateBinding CornerRadius} rather than a resource key. -->
  <Style Selector="ScrollBar /template/ Thumb">
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <!-- ════════════════════════════════════════════
       ICONS
       ════════════════════════════════════════════ -->

  <Style Selector="PathIcon.AppIcon">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
  </Style>

  <Style Selector="PathIcon.AppIconAccent">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
  </Style>

  <!-- Larger icon used inside active NavItem (inherits accent from parent) -->
  <Style Selector="Button.NavItem.Active PathIcon.AppIcon">
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
  </Style>

  <!-- Nav label text colours — placed last so specificity is unambiguous -->
  <Style Selector="Button.NavItem TextBlock.NavLabel">
    <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
  </Style>
  <Style Selector="Button.NavItem.Active TextBlock.NavLabel">
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>

  <!-- Flat content-area panel — no corner radius, for full-bleed layout regions -->
  <Style Selector="Border.AppPanelFlat">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="{DynamicResource Padding.CardCompact}" />
  </Style>

  <!-- Smaller icon-only button (36×36) for tight contexts like panel headers -->
  <Style Selector="Button.IconActionSm">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Small}" />
  </Style>
  <Style Selector="Button.IconActionSm /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
  </Style>
  <Style Selector="Button.IconActionSm:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="Button.IconActionSm:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppBorderBrush}" />
  </Style>


  <!-- ── Filter button ────────────────────────────────────────────────── -->
  <Style Selector="ToggleButton.FilterButton">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ToggleButton.FilterButton /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ToggleButton.FilterButton:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="ToggleButton.FilterButton:checked">
    <Setter Property="Background" Value="{DynamicResource AppAccentMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.FilterButton:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ToggleButton.FilterButton:checked:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrightBrush}" />
  </Style>
  <!-- FilterButton dropdown chevron foreground per state -->
  <Style Selector="ToggleButton.FilterButton PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
  </Style>
  <Style Selector="ToggleButton.FilterButton:checked PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.FilterButton:checked:pointerover PathIcon">
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrightBrush}" />
  </Style>

  <!-- ── Filter popup container ───────────────────────────────────────── -->
  <Style Selector="Border.FilterPopup">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceElevatedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
    <Setter Property="Padding" Value="16,14" />
  </Style>

  <!-- ── Filter section header ────────────────────────────────────────── -->
  <Style Selector="TextBlock.FilterSectionHeader">
    <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Xs}" />
    <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Margin" Value="0,0,0,6" />
  </Style>

  <!-- ── Filter "Clear all" outlined button ───────────────────────────── -->
  <Style Selector="Button.FilterClearButton">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Small}" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Sm}" />
    <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="Button.FilterClearButton /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="Button.FilterClearButton:pointerover">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="Button.FilterClearButton:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrightBrush}" />
  </Style>
  <Style Selector="Button.FilterClearButton:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentDimBrush}" />
  </Style>

  <!-- ── Genre chip: pill ToggleButton used in WrapPanel genre filter ──── -->
  <Style Selector="ToggleButton.GenreChip">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{DynamicResource Radius.Large}" />
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="FontSize" Value="{DynamicResource FontSize.Sm}" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,3,4,3" />
  </Style>
  <Style Selector="ToggleButton.GenreChip /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ToggleButton.GenreChip:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="ToggleButton.GenreChip:checked">
    <Setter Property="Background" Value="{DynamicResource AppAccentMutedBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
  </Style>
  <Style Selector="ToggleButton.GenreChip:checked /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>
  <Style Selector="ToggleButton.GenreChip:checked:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentBrightBrush}" />
  </Style>
  <Style Selector="ToggleButton.GenreChip:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}" />
  </Style>
  <Style Selector="ToggleButton.GenreChip:checked:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AppAccentSurfaceBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource AppAccentDimBrush}" />
  </Style>
  <Style Selector="ToggleButton.GenreChip:focus-visible">
    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrightBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>
  <Style Selector="ToggleButton.GenreChip:disabled">
    <Setter Property="Opacity" Value="0.4" />
  </Style></Styles>
