<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Librova.UI.ViewModels"
             x:Class="Librova.UI.Views.ImportView"
             x:DataType="viewModels:ShellViewModel"
             mc:Ignorable="d">
  <StackPanel Spacing="18">
    <Border Classes="SurfaceCard">
      <StackPanel Spacing="18">
        <StackPanel Spacing="6">
          <TextBlock Classes="SectionTitle"
                     Text="Import Books" />
          <TextBlock Opacity="0.72"
                     Text="Drop local `.fb2`, `.epub`, or `.zip` files and folders onto the window, or use `Select Files...` / `Select Folder...` to import them into the managed library."
                     TextWrapping="Wrap" />
        </StackPanel>

        <Border Classes="TintedCard"
                Background="#F6E8D7"
                BorderBrush="#D9BE98">
          <StackPanel Spacing="12">
            <TextBlock FontWeight="SemiBold"
                       Text="Drop files or folders here" />
            <TextBlock Opacity="0.82"
                       Text="Librova accepts `.fb2`, `.epub`, `.zip`, multiple selected files, and recursive folder imports. Selecting or dropping sources starts the import flow immediately."
                       TextWrapping="Wrap" />
            <WrapPanel Orientation="Horizontal"
                       ItemHeight="44">
              <Button Classes="PrimaryAction"
                      Width="180"
                      HorizontalAlignment="Left"
                      Command="{Binding ImportJobs.SelectSourceAndImportCommand}"
                      Content="Select Files..." />
              <Button Classes="SecondaryAction"
                      Width="180"
                      HorizontalAlignment="Left"
                      Command="{Binding ImportJobs.SelectDirectoryAndImportCommand}"
                      Content="Select Folder..." />
            </WrapPanel>
          </StackPanel>
        </Border>

        <TextBlock FontSize="12"
                   Foreground="#A04628"
                   IsVisible="{Binding ImportJobs.HasSourceValidationError}"
                   Text="{Binding ImportJobs.SourceValidationMessage}"
                   TextWrapping="Wrap" />
        <CheckBox IsChecked="{Binding ImportJobs.AllowProbableDuplicates}"
                  Content="Allow duplicate import" />
        <TextBlock Opacity="0.72"
                   Text="When enabled, Librova can continue after a probable duplicate warning and store the new book as a separate managed record."
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border Classes="SurfaceCard"
            IsVisible="{Binding ImportJobs.ShowRunningImportState}">
      <StackPanel Spacing="14">
        <TextBlock Classes="SectionTitle"
                   Text="Import In Progress" />
        <TextBlock FontSize="16"
                   FontWeight="SemiBold"
                   Text="{Binding ImportJobs.StatusText}" />
        <TextBlock Opacity="0.78"
                   Text="{Binding ImportJobs.SelectedSourcePathText}"
                   TextWrapping="Wrap" />
        <TextBlock Opacity="0.78"
                   Text="The import pipeline is running. Navigation and other actions stay locked until the import finishes or is cancelled."
                   TextWrapping="Wrap" />
        <WrapPanel>
          <Button Classes="SecondaryAction"
                  Width="140"
                  Command="{Binding ImportJobs.CancelImportCommand}"
                  Content="Cancel" />
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border Classes="SurfaceCard"
            IsVisible="{Binding ImportJobs.HasImportResult}">
      <StackPanel Spacing="14">
        <TextBlock Classes="SectionTitle"
                   Text="Last Import Result" />
        <TextBlock FontSize="16"
                   FontWeight="SemiBold"
                   Text="{Binding ImportJobs.StatusText}" />
        <StackPanel Spacing="6">
          <TextBlock FontWeight="SemiBold"
                     Text="Imported Source" />
          <TextBlock Text="{Binding ImportJobs.SelectedSourcePathText}"
                     TextWrapping="Wrap" />
        </StackPanel>
        <TextBlock Text="{Binding ImportJobs.ResultSummaryText}"
                   TextWrapping="Wrap" />

        <StackPanel Spacing="6">
          <TextBlock FontWeight="SemiBold"
                     Text="Warnings" />
          <TextBlock Text="{Binding ImportJobs.WarningsText}"
                     TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="6">
          <TextBlock FontWeight="SemiBold"
                     Text="Error" />
          <TextBlock Text="{Binding ImportJobs.ErrorText}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
