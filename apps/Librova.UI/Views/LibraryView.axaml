<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Librova.UI.ViewModels"
             x:Class="Librova.UI.Views.LibraryView"
             x:DataType="viewModels:ShellViewModel"
             mc:Ignorable="d">
  <StackPanel Spacing="18">
    <Border Classes="SurfaceCard">
      <StackPanel Spacing="14">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
          <StackPanel Spacing="4">
            <TextBlock Classes="SectionTitle"
                       Text="Library" />
            <TextBlock Opacity="0.72"
                       Text="{Binding LibraryBrowser.StatusText}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <Button Grid.Column="1"
                  Classes="SecondaryAction"
                  Width="140"
                  Command="{Binding LibraryBrowser.RefreshCommand}"
                  Content="Refresh List" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="10">
          <TextBox Classes="ImportField"
                   Watermark="Search imported books"
                   Text="{Binding LibraryBrowser.SearchText}" />
          <Button Grid.Column="1"
                  Classes="SecondaryAction"
                  Width="120"
                  Command="{Binding LibraryBrowser.PreviousPageCommand}"
                  Content="Previous" />
          <Button Grid.Column="2"
                  Classes="SecondaryAction"
                  Width="120"
                  Command="{Binding LibraryBrowser.NextPageCommand}"
                  Content="Next" />
        </Grid>

        <Grid ColumnDefinitions="1.2*,1.1*,0.7*,0.6*,Auto"
              ColumnSpacing="10">
          <TextBox Classes="ImportField"
                   Watermark="Author filter"
                   Text="{Binding LibraryBrowser.AuthorFilter}" />
          <TextBox Grid.Column="1"
                   Classes="ImportField"
                   Watermark="Language filter"
                   Text="{Binding LibraryBrowser.LanguageFilter}" />
          <ComboBox Grid.Column="2"
                    MinHeight="44"
                    SelectedItem="{Binding LibraryBrowser.SelectedFormatFilter}"
                    ItemsSource="{Binding LibraryBrowser.AvailableFormatFilters}" />
          <ComboBox Grid.Column="3"
                    MinHeight="44"
                    SelectedItem="{Binding LibraryBrowser.SelectedSort}"
                    ItemsSource="{Binding LibraryBrowser.AvailableSortOptions}" />
          <Border Grid.Column="4"
                  Background="#EFE3D5"
                  CornerRadius="14"
                  Padding="14,10">
            <StackPanel Spacing="2">
              <TextBlock HorizontalAlignment="Center"
                         Text="{Binding LibraryBrowser.BookCountText}" />
              <TextBlock HorizontalAlignment="Center"
                         FontSize="11"
                         Opacity="0.74"
                         Text="{Binding LibraryBrowser.PageLabelText}" />
            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>
    </Border>

    <Grid ColumnDefinitions="1.05*,0.95*"
          ColumnSpacing="14">
      <ListBox ItemsSource="{Binding LibraryBrowser.Books}"
               SelectedItem="{Binding LibraryBrowser.SelectedBook}"
               BorderThickness="0"
               Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Background="#FAF6F0"
                    BorderBrush="#E3D8CA"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="14"
                    Margin="0,0,0,8">
              <StackPanel Spacing="6">
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Text="{Binding Title}" />
                <TextBlock Opacity="0.82"
                           Text="{Binding AuthorsText}"
                           TextWrapping="Wrap" />
                <WrapPanel ItemHeight="28">
                  <Border Background="#E8DED0"
                          CornerRadius="10"
                          Padding="8,4"
                          Margin="0,0,8,0">
                    <TextBlock Text="{Binding FormatText}" />
                  </Border>
                  <TextBlock VerticalAlignment="Center"
                             Opacity="0.72"
                             Text="{Binding Language, StringFormat='Language: {0}'}" />
                </WrapPanel>
                <TextBlock FontSize="12"
                           Opacity="0.64"
                           Text="{Binding ManagedPath}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Border Grid.Column="1"
              Background="#F5EFE7"
              BorderBrush="#E3D7C8"
              BorderThickness="1"
              CornerRadius="18"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Classes="SectionTitle"
                     Text="Selection Details" />
          <TextBlock FontSize="16"
                     FontWeight="SemiBold"
                     Text="{Binding LibraryBrowser.SelectedBookTitle}" />
          <TextBlock Text="{Binding LibraryBrowser.SelectedBookDetailsText}"
                     TextWrapping="Wrap" />
          <Button Classes="SecondaryAction"
                  Width="160"
                  Command="{Binding LibraryBrowser.LoadDetailsCommand}"
                  Content="Load Full Details" />
          <Button Classes="SecondaryAction"
                  Width="160"
                  Command="{Binding LibraryBrowser.ExportSelectedBookCommand}"
                  Content="Export Book..." />
          <Button Classes="SecondaryAction"
                  Width="160"
                  Command="{Binding LibraryBrowser.MoveSelectedBookToTrashCommand}"
                  Content="Move To Trash" />
          <Border Background="#EFE5D8"
                  CornerRadius="12"
                  Padding="12">
            <StackPanel Spacing="6">
              <TextBlock FontWeight="SemiBold"
                         Text="Extended Metadata" />
              <TextBlock FontSize="12"
                         Text="{Binding LibraryBrowser.SelectedBookExtendedDetailsText}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Background="#EFE5D8"
                  CornerRadius="12"
                  Padding="12">
            <StackPanel Spacing="6">
              <TextBlock FontWeight="SemiBold"
                         Text="Managed Path" />
              <TextBlock FontSize="12"
                         Text="{Binding LibraryBrowser.SelectedBookPathText}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
    </Grid>
  </StackPanel>
</UserControl>
