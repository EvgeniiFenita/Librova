<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Librova.UI.ViewModels"
             x:Class="Librova.UI.Views.LibraryView"
             x:Name="LibraryRootView"
             x:DataType="viewModels:ShellViewModel"
             mc:Ignorable="d">
  <UserControl.Styles>
    <Style Selector="Border.LibraryToolbar">
      <Setter Property="Background" Value="#FFF9F1" />
      <Setter Property="BorderBrush" Value="#D8CCBD" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="20" />
    </Style>
    <Style Selector="Button.BookCardButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Border.BookCard">
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Border.BookCardHoverChrome">
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Background" Value="#00FFFFFF" />
      <Setter Property="BorderBrush" Value="#00FFFFFF" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.BookCardButton:pointerover Border.BookCardHoverChrome:not(.Selected)">
      <Setter Property="Background" Value="#14FFF8EF" />
      <Setter Property="BorderBrush" Value="#C68F684C" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Border.CoverSlot">
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="TextBlock.MetaLabel">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="0.76" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*"
        RowSpacing="18">
    <Border Classes="LibraryToolbar">
      <Grid ColumnDefinitions="2.2*,1.1*,Auto"
            ColumnSpacing="12">
        <TextBox Classes="ImportField"
                 Watermark="Search titles, authors, tags, and descriptions..."
                 Text="{Binding LibraryBrowser.SearchText, UpdateSourceTrigger=PropertyChanged}" />
        <ComboBox Grid.Column="1"
                  MinHeight="44"
                  SelectedItem="{Binding LibraryBrowser.SelectedLanguageFilter}"
                  ItemsSource="{Binding LibraryBrowser.AvailableLanguageFilters}" />
        <Border Grid.Column="2"
                Background="#F1E3D3"
                CornerRadius="14"
                Padding="18,10"
                MinWidth="128">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Text="{Binding LibraryBrowser.BookCountText}" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="18">
      <Border Classes="SurfaceCard"
              Padding="18">
        <Grid RowDefinitions="*">
          <Border Classes="TintedCard"
                  Background="#F6E8D7"
                  BorderBrush="#D9BE98"
                  IsVisible="{Binding LibraryBrowser.ShowEmptyState}">
            <StackPanel Spacing="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="420">
              <TextBlock FontSize="38"
                         HorizontalAlignment="Center"
                         Text="⌕" />
              <TextBlock FontSize="22"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center"
                         Text="{Binding LibraryBrowser.EmptyStateTitle}" />
              <TextBlock HorizontalAlignment="Center"
                         Text="{Binding LibraryBrowser.EmptyStateDescription}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <ScrollViewer x:Name="BooksViewport"
                        IsVisible="{Binding LibraryBrowser.HasBooks}"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ItemsControl Width="{Binding #BooksViewport.Bounds.Width}"
                          ItemsSource="{Binding LibraryBrowser.Books}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Classes="BookCardButton"
                          Width="184"
                          Height="314"
                          Margin="0,0,16,16"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Command="{Binding #LibraryRootView.DataContext.LibraryBrowser.SelectBookCommand}"
                          CommandParameter="{Binding .}">
                    <Border Classes="BookCard"
                            Height="314">
                      <Border.Background>
                        <Binding Path="CardBackgroundBrush" />
                      </Border.Background>
                      <Border.BorderBrush>
                        <Binding Path="CardBorderBrush" />
                      </Border.BorderBrush>
                      <Border.BorderThickness>
                        <Binding Path="CardBorderThickness" />
                      </Border.BorderThickness>
                      <Grid>
                        <Border Classes="BookCardHoverChrome"
                                Classes.Selected="{Binding IsSelected}"
                                IsHitTestVisible="False" />
                        <Grid Margin="12"
                              RowDefinitions="Auto,*"
                              RowSpacing="10">
                          <Border Classes="CoverSlot"
                                  Width="160"
                                  Height="240"
                                  HorizontalAlignment="Center"
                                  Background="{Binding CoverBackgroundBrush}">
                            <Grid>
                              <Image IsVisible="{Binding HasResolvedCover}"
                                     Source="{Binding ResolvedCoverImage}"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch" />
                              <TextBlock IsVisible="{Binding ShowCoverPlaceholder}"
                                         FontSize="42"
                                         FontWeight="Bold"
                                         Foreground="#FFF8EF"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Text="{Binding CoverPlaceholderText}" />
                            </Grid>
                          </Border>
                          <TextBlock Grid.Row="1"
                                     FontWeight="SemiBold"
                                     HorizontalAlignment="Center"
                                     TextAlignment="Center"
                                     MaxWidth="160"
                                     MinHeight="42"
                                     MaxHeight="42"
                                     Text="{Binding Title}"
                                     TextWrapping="Wrap"
                                     TextTrimming="CharacterEllipsis" />
                        </Grid>
                      </Grid>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Classes="SurfaceCard"
              Width="380"
              Padding="18"
              HorizontalAlignment="Left"
              VerticalAlignment="Stretch"
              IsVisible="{Binding LibraryBrowser.ShowDetailsPanel}">
        <Grid RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="14">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="10">
            <TextBlock Classes="SectionTitle"
                       Text="Selection Details" />
            <Button Grid.Column="1"
                    Classes="SecondaryAction"
                    Width="44"
                    Command="{Binding LibraryBrowser.CloseSelectionCommand}"
                    Content="×" />
          </Grid>

          <Grid Grid.Row="1"
                ColumnDefinitions="140,*"
                ColumnSpacing="14">
            <Border Classes="CoverSlot"
                    Width="140"
                    Height="210"
                    VerticalAlignment="Top"
                    Background="{Binding LibraryBrowser.SelectedBookCoverBackgroundBrush}">
              <Grid>
                <Image IsVisible="{Binding LibraryBrowser.HasSelectedBookCover}"
                       Source="{Binding LibraryBrowser.SelectedBookCoverImage}"
                       Stretch="Uniform"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch" />
                <TextBlock IsVisible="{Binding LibraryBrowser.ShowSelectedBookCoverPlaceholder}"
                           FontSize="64"
                           FontWeight="Bold"
                           Foreground="#FFF8EF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="{Binding LibraryBrowser.SelectedBookCoverPlaceholderText}" />
              </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        Spacing="8">
              <TextBlock FontSize="24"
                         FontWeight="Bold"
                         Text="{Binding LibraryBrowser.SelectedBookTitle}"
                         TextWrapping="Wrap" />
              <TextBlock FontSize="15"
                         Opacity="0.78"
                         Text="{Binding LibraryBrowser.SelectedBookAuthorText}"
                         TextWrapping="Wrap" />
              <TextBlock IsVisible="{Binding LibraryBrowser.ShowDetailsPanelLoading}"
                         Opacity="0.68"
                         Text="Loading details..." />

              <ItemsControl ItemsSource="{Binding LibraryBrowser.SelectedBookMetadataPairs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="10"
                          Margin="0,0,0,6">
                      <TextBlock Classes="MetaLabel"
                                 Text="{Binding Label}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Value}"
                                 TextWrapping="Wrap" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>

          <ScrollViewer Grid.Row="2"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="14">
              <StackPanel Spacing="6">
                <TextBlock Classes="MetaLabel"
                           Text="Annotation" />
                <Border Background="#F5EBDD"
                        BorderBrush="#E2D2BF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                  <TextBlock Text="{Binding LibraryBrowser.SelectedBookAnnotationText}"
                             TextWrapping="Wrap" />
                </Border>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>

          <StackPanel Grid.Row="3"
                      Spacing="10">
            <Button Classes="PrimaryAction"
                    HorizontalAlignment="Stretch"
                    IsVisible="{Binding LibraryBrowser.ShowExportAsEpubAction}"
                    Command="{Binding LibraryBrowser.ExportSelectedBookAsEpubCommand}"
                    Content="Export As EPUB" />
            <Button Classes="PrimaryAction"
                    HorizontalAlignment="Stretch"
                    Command="{Binding LibraryBrowser.ExportSelectedBookCommand}"
                    Content="Export" />
            <Button Classes="DestructiveAction"
                    HorizontalAlignment="Stretch"
                    Command="{Binding LibraryBrowser.MoveSelectedBookToTrashCommand}"
                    Content="Move To Trash" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
