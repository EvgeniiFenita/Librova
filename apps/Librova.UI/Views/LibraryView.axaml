<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Librova.UI.ViewModels"
             xmlns:models="using:Librova.UI.LibraryCatalog"
             x:Class="Librova.UI.Views.LibraryView"
             x:Name="LibraryRootView"
             x:DataType="viewModels:ShellViewModel"
             mc:Ignorable="d">
  <UserControl.Styles>

    <!-- Fade in when section becomes visible -->
    <Style Selector="UserControl:visible">
      <Style.Animations>
        <Animation Duration="0:0:0.15" FillMode="None">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Toolbar pill -->
    <Style Selector="Border.LibraryToolbar">
      <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Padding" Value="20,12" />
    </Style>

    <!-- Transparent book-card button wrapper -->
    <Style Selector="Button.BookCardButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
        </ControlTemplate>
      </Setter>
    </Style>

    <!-- Book card surface -->
    <Style Selector="Border.BookCard">
      <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
      <Setter Property="BoxShadow" Value="0 2 12 0 #30000000" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <!-- Hover overlay (fills BookCard area) -->
    <Style Selector="Border.BookCardHoverChrome">
      <Setter Property="CornerRadius" Value="{DynamicResource Radius.Medium}" />
      <Setter Property="Background" Value="#00FFFFFF" />
      <Setter Property="BorderBrush" Value="#00FFFFFF" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Non-selected hover -->
    <Style Selector="Button.BookCardButton:pointerover Border.BookCardHoverChrome:not(.Selected)">
      <Setter Property="Background" Value="#0CFFFFFF" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- Ambient amber glow on hover for all book cards.
         BoxShadow colour cannot use DynamicResource (Avalonia limitation) —
         value mirrors Color.AccentGlow token (#38F5A623). Update together. -->
    <Style Selector="Button.BookCardButton:pointerover Border.BookCard">
      <Setter Property="BoxShadow" Value="0 4 18 0 #38F5A623" />
    </Style>

  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- Toolbar -->
    <Border Classes="LibraryToolbar">
      <Grid ColumnDefinitions="*,Auto,Auto"
            ColumnSpacing="16">

        <!-- Zone 1: Search (fills remaining space) -->
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="10"
              VerticalAlignment="Center">
          <PathIcon Classes="AppIcon"
                    Width="16"
                    Height="16"
                    VerticalAlignment="Center"
                    Data="{StaticResource IconSearch}" />
          <TextBox Grid.Column="1"
                   Classes="AppTextInput"
                   PlaceholderText="Search titles, authors, tags..."
                   Text="{Binding LibraryBrowser.SearchText, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <!-- Zone 2: View options cluster (language filter + genre filter + sort group) -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">

          <!-- Filter button + flyout -->
          <ToggleButton x:Name="FilterBtn"
                        Classes="FilterButton"
                        IsChecked="{Binding LibraryBrowser.IsFilterPanelOpen, Mode=TwoWay}">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <TextBlock Text="{Binding LibraryBrowser.FilterButtonLabel}"
                         VerticalAlignment="Center" />
              <PathIcon Width="10" Height="10"
                        VerticalAlignment="Center"
                        Data="{StaticResource IconChevronDown}" />
            </StackPanel>
          </ToggleButton>
          <Popup x:Name="FilterPopup"
                 IsOpen="{Binding LibraryBrowser.IsFilterPanelOpen, Mode=TwoWay}"
                 IsLightDismissEnabled="True"
                 Placement="Bottom"
                 VerticalOffset="6">
            <Border Classes="FilterPopup" Width="420">
              <StackPanel Spacing="0">
                <!-- LANGUAGES section -->
                <TextBlock Classes="FilterSectionHeader" Text="LANGUAGES" />
                <ScrollViewer MaxHeight="100" Margin="0,0,0,12">
                  <ItemsControl ItemsSource="{Binding LibraryBrowser.LanguageFacets}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="viewModels:FilterFacetItem">
                        <ToggleButton Classes="GenreChip"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding Value}" />
                            <TextBlock Text="{Binding BookCount, StringFormat='({0})'}"
                                       Opacity="0.55"
                                       FontSize="10"
                                       VerticalAlignment="Center" />
                          </StackPanel>
                        </ToggleButton>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <!-- Divider -->
                <Border Height="1"
                        Margin="0,0,0,12"
                        Background="{DynamicResource AppBorderStrongBrush}" />
                <!-- GENRES section with search -->
                <TextBlock Classes="FilterSectionHeader" Text="GENRES" />
                <TextBox Classes="AppTextBox"
                         PlaceholderText="Search genres…"
                         Text="{Binding LibraryBrowser.GenreSearchText, Mode=TwoWay}"
                         Margin="0,0,0,6" />
                <ScrollViewer MaxHeight="200" Margin="0,0,0,12">
                  <ItemsControl ItemsSource="{Binding LibraryBrowser.FilteredGenreFacets}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="viewModels:FilterFacetItem">
                        <ToggleButton Classes="GenreChip"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding Value}" />
                            <TextBlock Text="{Binding BookCount, StringFormat='({0})'}"
                                       Opacity="0.55"
                                       FontSize="10"
                                       VerticalAlignment="Center" />
                          </StackPanel>
                        </ToggleButton>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
                <!-- Footer -->
                <Border Height="1"
                        Margin="0,0,0,10"
                        Background="{DynamicResource AppBorderStrongBrush}"
                        IsVisible="{Binding LibraryBrowser.HasActiveFilters}" />
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            IsVisible="{Binding LibraryBrowser.HasActiveFilters}">
                  <TextBlock Text="{Binding LibraryBrowser.ActiveFilterCountText}"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource AppTextSecondaryBrush}"
                             FontSize="{DynamicResource FontSize.Sm}" />
                  <Button Classes="FilterClearButton"
                          Command="{Binding LibraryBrowser.ClearAllFiltersCommand}"
                          Content="Clear all" />
                </StackPanel>
              </StackPanel>
            </Border>
          </Popup>

          <!-- Vertical divider -->
          <Border Width="1"
                  Margin="4,6"
                  Background="{DynamicResource AppBorderStrongBrush}" />

          <!-- Sort group: key selector + direction toggle in one unified pill -->
          <Border Classes="SortGroup">
            <StackPanel Orientation="Horizontal">
              <ComboBox Classes="AppComboBox"
                        MinWidth="110"
                        ItemsSource="{Binding LibraryBrowser.AvailableSortKeys}"
                        SelectedItem="{Binding LibraryBrowser.SelectedSortKey}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="models:SortKeyOption">
                    <TextBlock Text="{Binding Label}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <!-- Direction toggle (left border acts as separator — avoids ClipToBounds artifact) -->
              <Button Classes="IconAction"
                      Command="{Binding LibraryBrowser.ToggleSortDirectionCommand}"
                      ToolTip.Tip="Toggle sort direction">
                <Panel Width="14"
                       Height="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                  <PathIcon IsVisible="{Binding !LibraryBrowser.SortDescending}"
                            Classes="AppIcon"
                            Width="14"
                            Height="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="{StaticResource IconSortAsc}" />
                  <PathIcon IsVisible="{Binding LibraryBrowser.SortDescending}"
                            Classes="AppIcon"
                            Width="14"
                            Height="14"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="{StaticResource IconSortDesc}" />
                </Panel>
              </Button>
            </StackPanel>
          </Border>

        </StackPanel>

        <!-- Zone 3: Book count accent stat -->
        <Border Grid.Column="2"
                Classes="MetricPillAccent"
                MinWidth="110">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Text="{Binding LibraryBrowser.BookCountText}" />
        </Border>

      </Grid>
    </Border>

    <!-- Book grid + details -->
    <Grid Grid.Row="1"
          ColumnDefinitions="*,Auto">

      <!-- Book grid panel -->
      <Border Classes="AppPanelFlat"
              Padding="16">
        <Grid>

          <!-- Empty state -->
          <Border Classes="AccentPanel"
                  IsVisible="{Binding LibraryBrowser.ShowEmptyState}">
            <StackPanel Spacing="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="420">

              <!-- Open book illustration: shown only when library is truly empty and refresh is complete -->
              <Canvas x:Name="EmptyLibraryIllustration"
                      Width="220" Height="150"
                      HorizontalAlignment="Center"
                      IsVisible="{Binding LibraryBrowser.ShowGoToImportButton}">

                <!-- Warm ambient glow behind the book -->
                <Ellipse Canvas.Left="20" Canvas.Top="8"
                         Width="180" Height="134"
                         Fill="{DynamicResource EmptyStateGlowBrush}" />

                <!-- Left page cover (dark sepia) -->
                <Path Fill="{DynamicResource EmptyStateLeatherBrush}"
                      Data="M25,26 L110,26 L110,124 L25,124 Z" />
                <!-- Left page paper (parchment) -->
                <Path Fill="{DynamicResource EmptyStateParchmentBrush}"
                      Data="M27,28 L108,28 L108,122 L27,122 Z" />
                <!-- Left page text lines -->
                <Path Stroke="{DynamicResource EmptyStateLineBrush}" StrokeThickness="1.5" Opacity="0.5"
                      Data="M33,41 L103,41 M33,51 L103,51 M33,61 L103,61 M33,71 L103,71 M33,81 L89,81 M33,91 L103,91 M33,101 L103,101 M33,111 L91,111" />

                <!-- Right page cover (dark sepia) -->
                <Path Fill="{DynamicResource EmptyStateLeatherBrush}"
                      Data="M110,26 L195,26 L195,124 L110,124 Z" />
                <!-- Right page paper (parchment) -->
                <Path Fill="{DynamicResource EmptyStateParchmentBrush}"
                      Data="M112,28 L193,28 L193,122 L112,122 Z" />
                <!-- Right page text lines -->
                <Path Stroke="{DynamicResource EmptyStateLineBrush}" StrokeThickness="1.5" Opacity="0.5"
                      Data="M117,41 L187,41 M117,51 L187,51 M117,61 L187,61 M117,71 L187,71 M117,81 L175,81 M117,91 L187,91 M117,101 L187,101 M117,111 L179,111" />

                <!-- Page turning – leaf 1: slight lift, rectangular cross-section -->
                <Path Fill="{DynamicResource EmptyStateLeaf1Brush}" Stroke="{DynamicResource EmptyStateLeaf1BorderBrush}" StrokeThickness="0.75"
                      Data="M 111,26 C 133,22 158,23 164,30 C 166,50 166,100 162,116 C 155,123 131,123 111,124 Z" />
                <!-- Page turning – leaf 2: medium lift -->
                <Path Fill="{DynamicResource EmptyStateLeaf2Brush}" Stroke="{DynamicResource EmptyStateLeaf2BorderBrush}" StrokeThickness="0.75"
                      Data="M 111,26 C 136,16 163,17 171,25 C 174,46 174,104 169,119 C 161,129 135,129 111,124 Z" />
                <!-- Page turning – leaf 3: fully lifted, extends near right edge -->
                <Path Fill="{DynamicResource EmptyStateLeaf3Brush}" Stroke="{DynamicResource EmptyStateLeaf3BorderBrush}" StrokeThickness="0.75"
                      Data="M 111,26 C 140,8 168,9 178,18 C 182,41 182,109 176,122 C 167,134 139,134 111,124 Z" />

                <!-- Spine strip -->
                <Path Fill="{DynamicResource EmptyStateSpineBrush}"
                      Data="M106,24 L114,24 L114,126 L106,126 Z" />
                <!-- Spine centre highlight -->
                <Path Fill="{DynamicResource EmptyStateSpineHighlightBrush}"
                      Data="M109,24 L111,24 L111,126 L109,126 Z" />

              </Canvas>

              <!-- "Nothing found" illustration: magnifier in book-style warm palette -->
              <Canvas x:Name="NoResultsIllustration"
                      Width="150" Height="150"
                      HorizontalAlignment="Center"
                      IsVisible="{Binding LibraryBrowser.ShowClearFiltersButton}">

                <!-- Warm amber glow -->
                <Ellipse Canvas.Left="5" Canvas.Top="5" Width="110" Height="110"
                         Fill="{DynamicResource EmptyStateGlowSoftBrush}" />

                <!-- Outer lens rim (dark sepia, like book cover) -->
                <Ellipse Canvas.Left="8" Canvas.Top="8" Width="104" Height="104"
                         Fill="{DynamicResource EmptyStateLeatherBrush}" />

                <!-- Inner lens face (parchment, like book page) -->
                <Ellipse Canvas.Left="16" Canvas.Top="16" Width="88" Height="88"
                         Fill="{DynamicResource EmptyStateParchmentBrush}" />

                <!-- Faint page lines inside lens -->
                <Path Stroke="{DynamicResource EmptyStateLineBrush}" StrokeThickness="1.5" Opacity="0.35"
                      Data="M 34,48 L 86,48 M 28,57 L 92,57 M 26,66 L 94,66 M 28,75 L 92,75 M 34,84 L 86,84" />

                <!-- × mark (dark sepia, reads well on parchment) -->
                <Path Stroke="{DynamicResource EmptyStateSearchCrossBrush}" StrokeThickness="4.5" StrokeLineCap="Round"
                      Data="M 36,36 L 84,84 M 84,36 L 36,84" />

                <!-- Handle body (dark leather) -->
                <Path Stroke="{DynamicResource EmptyStateSearchHandleBrush}" StrokeThickness="14" StrokeLineCap="Round"
                      Data="M 95,95 L 130,130" />
                <!-- Handle highlight (inner warmth) -->
                <Path Stroke="{DynamicResource EmptyStateSpineHighlightBrush}" StrokeThickness="5" StrokeLineCap="Round"
                      Data="M 95,95 L 130,130" />

                <!-- Lens rim accent (thin amber ring) -->
                <Ellipse Canvas.Left="8" Canvas.Top="8" Width="104" Height="104"
                         Stroke="{DynamicResource EmptyStateAccentRingBrush}" StrokeThickness="1.5" Fill="Transparent" />

              </Canvas>

              <TextBlock Classes="ViewTitle"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         Text="{Binding LibraryBrowser.EmptyStateTitle}" />

              <!-- CTA: no active filters -->
              <Button x:Name="GoToImportButton"
                      Classes="OutlineAccent"
                      IsVisible="{Binding LibraryBrowser.ShowGoToImportButton}"
                      Command="{Binding LibraryBrowser.GoToImportCommand}"
                      HorizontalAlignment="Center"
                      Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <PathIcon Width="16" Height="16"
                            Data="{StaticResource IconImport}" />
                  <TextBlock Text="Go to Import" />
                </StackPanel>
              </Button>

            </StackPanel>
          </Border>

          <!-- Scrollable book grid -->
          <ScrollViewer x:Name="BooksViewport"
                        IsVisible="{Binding LibraryBrowser.HasBooks}"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Width="{Binding #BooksViewport.Bounds.Width}"
                        Spacing="0">
              <ItemsControl ItemsSource="{Binding LibraryBrowser.Books}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:BookListItemModel">
                    <Button Classes="BookCardButton"
                            Width="172"
                            Height="300"
                            Margin="0,0,14,14"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            ContextRequested="OnBookCardContextRequested"
                            Command="{Binding #LibraryRootView.DataContext.LibraryBrowser.SelectBookCommand}"
                            CommandParameter="{Binding .}">
                        <Button.ContextMenu>
                          <ContextMenu Classes="BookCardContextMenu"
                                       DataContext="{Binding .}">
                            <MenuItem Classes="BookCardContextItem"
                                      Header="Export"
                                      Command="{Binding #LibraryRootView.DataContext.LibraryBrowser.ExportBookFromCardCommand}"
                                      CommandParameter="{Binding .}">
                              <MenuItem.Icon>
                                <PathIcon Width="16"
                                          Height="16"
                                          Data="{StaticResource IconExport}" />
                              </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Classes="BookCardContextItem"
                                      Header="Export as EPUB"
                                      IsVisible="{Binding #LibraryRootView.DataContext.HasConfiguredConverter}"
                                      Command="{Binding #LibraryRootView.DataContext.LibraryBrowser.ExportBookAsEpubFromCardCommand}"
                                      CommandParameter="{Binding .}">
                              <MenuItem.Icon>
                                <PathIcon Width="16"
                                          Height="16"
                                          Data="{StaticResource IconExport}" />
                              </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Classes="BookCardContextItem"
                                      Header="Copy Title"
                                      Command="{Binding #LibraryRootView.DataContext.LibraryBrowser.CopyBookTitleCommand}"
                                      CommandParameter="{Binding .}">
                              <MenuItem.Icon>
                                <PathIcon Width="16"
                                          Height="16"
                                          Data="{StaticResource IconCopy}" />
                              </MenuItem.Icon>
                            </MenuItem>
                            <Separator Classes="BookCardContextSeparator" />
                            <MenuItem Classes="BookCardContextItem Destructive"
                                      Header="Move to Trash"
                                      Command="{Binding #LibraryRootView.DataContext.LibraryBrowser.MoveBookToTrashFromCardCommand}"
                                      CommandParameter="{Binding .}">
                              <MenuItem.Icon>
                                <PathIcon Width="16"
                                          Height="16"
                                          Data="{StaticResource IconTrash}" />
                              </MenuItem.Icon>
                            </MenuItem>
                          </ContextMenu>
                        </Button.ContextMenu>
                        <Border Classes="BookCard"
                              Height="300">
                        <Border.BorderBrush>
                          <Binding Path="CardPresentation.CardBorderBrush" />
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                          <Binding Path="CardPresentation.CardBorderThickness" />
                        </Border.BorderThickness>
                        <Grid>
                          <Border Classes="BookCardHoverChrome"
                                  Classes.Selected="{Binding CardPresentation.IsSelected}"
                                  IsHitTestVisible="False" />
                          <Grid Margin="10"
                                RowDefinitions="Auto,*"
                                RowSpacing="10">
                            <Border Classes="CoverMatte"
                                    Width="152"
                                    Height="228"
                                    HorizontalAlignment="Center"
                                    Background="{Binding CoverPresentation.CoverBackgroundBrush}">
                              <Grid>
                                <Image IsVisible="{Binding CoverPresentation.HasResolvedCover}"
                                       Source="{Binding CoverPresentation.ResolvedCoverImage}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch" />
                                <Viewbox IsVisible="{Binding CoverPresentation.ShowCoverPlaceholder}"
                                         Width="104"
                                         Height="104"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Stretch="Uniform">
                                  <Border Padding="8,12,8,20">
                                    <TextBlock FontSize="48"
                                               FontWeight="Bold"
                                               LineHeight="80"
                                               Foreground="{DynamicResource AppCoverPlaceholderBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               Text="{Binding CoverPresentation.CoverPlaceholderText}" />
                                  </Border>
                                </Viewbox>
                              </Grid>
                            </Border>
                            <TextBlock Grid.Row="1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       MaxWidth="152"
                                       MinHeight="38"
                                       MaxHeight="38"
                                       Text="{Binding Title}"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis" />
                          </Grid>
                        </Grid>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock HorizontalAlignment="Center"
                         Margin="0,0,0,12"
                         Classes="Caption"
                         IsVisible="{Binding LibraryBrowser.ShowLoadMoreIndicator}"
                         Text="Loading more books..." />
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

      <!-- Details panel -->
      <Border Grid.Column="1"
              Background="{DynamicResource AppSurfaceMutedBrush}"
              BorderBrush="{DynamicResource AppBorderBrush}"
              BorderThickness="1,0,0,0"
              Width="360"
              Padding="18"
              HorizontalAlignment="Left"
              VerticalAlignment="Stretch"
              IsVisible="{Binding LibraryBrowser.ShowDetailsPanel}">
        <Grid RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="16">

          <!-- Panel header -->
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="10">
            <StackPanel Spacing="2">
              <TextBlock Classes="SectionEyebrow"
                         Text="SELECTED" />
              <TextBlock Classes="SectionTitle"
                         Text="Book Details" />
            </StackPanel>
            <Button Grid.Column="1"
                    Classes="IconActionSm"
                    Command="{Binding LibraryBrowser.CloseSelectionCommand}">
              <PathIcon Classes="AppIcon"
                        Width="14"
                        Height="14"
                        Data="{StaticResource IconClose}" />
            </Button>
          </Grid>

          <!-- Cover + core metadata -->
          <Grid Grid.Row="1"
                ColumnDefinitions="130,*"
                ColumnSpacing="14">
            <Border Classes="CoverMatte"
                    Width="130"
                    Height="196"
                    VerticalAlignment="Top"
                    Background="{Binding LibraryBrowser.SelectedBookCoverBackgroundBrush}">
              <Grid>
                <Image IsVisible="{Binding LibraryBrowser.HasSelectedBookCover}"
                       Source="{Binding LibraryBrowser.SelectedBookCoverImage}"
                       Stretch="Uniform"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch" />
                <Viewbox IsVisible="{Binding LibraryBrowser.ShowSelectedBookCoverPlaceholder}"
                         Width="112"
                         Height="112"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Stretch="Uniform">
                  <Border Padding="8,14,8,24">
                    <TextBlock FontSize="58"
                               FontWeight="Bold"
                               LineHeight="96"
                               Foreground="{DynamicResource AppCoverPlaceholderBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Text="{Binding LibraryBrowser.SelectedBookCoverPlaceholderText}" />
                  </Border>
                </Viewbox>
              </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        Spacing="8">
              <TextBlock Classes="SectionTitle"
                         Text="{Binding LibraryBrowser.SelectedBookTitle}"
                         TextWrapping="Wrap" />
              <TextBlock Classes="BodyMuted"
                         FontSize="13"
                         Text="{Binding LibraryBrowser.SelectedBookAuthorText}"
                         TextWrapping="Wrap" />
              <TextBlock IsVisible="{Binding LibraryBrowser.ShowDetailsPanelLoading}"
                         Classes="Caption"
                         Text="Loading details..." />
              <ItemsControl ItemsSource="{Binding LibraryBrowser.SelectedBookMetadataPairs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="viewModels:MetadataPair">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8"
                          Margin="0,0,0,5">
                      <TextBlock Classes="MetaLabel"
                                 Text="{Binding Label}" />
                      <TextBlock Grid.Column="1"
                                 Classes="Caption"
                                 Foreground="{DynamicResource AppTextSecondaryBrush}"
                                 Text="{Binding Value}"
                                 TextWrapping="Wrap" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>

          <!-- Annotation -->
          <ScrollViewer Grid.Row="2"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="8">
              <TextBlock Classes="MetaLabel"
                         Text="ANNOTATION" />
              <Border Classes="AppPanelMuted"
                      Padding="12">
                <TextBlock Classes="BodyMuted"
                           FontSize="13"
                           FontStyle="Italic"
                           Text="{Binding LibraryBrowser.SelectedBookAnnotationText}"
                           TextWrapping="Wrap" />
              </Border>
            </StackPanel>
          </ScrollViewer>

          <!-- Actions -->
          <StackPanel Grid.Row="3"
                      Spacing="8">
            <!-- Export in-progress indicator -->
            <Border Classes="AccentPanel"
                    IsVisible="{Binding LibraryBrowser.IsExportBusy}"
                    Padding="12">
              <StackPanel Spacing="8">
                <TextBlock FontSize="13"
                           FontWeight="SemiBold"
                           Text="{Binding LibraryBrowser.StatusText}" />
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             CornerRadius="2"
                             Foreground="{DynamicResource AppAccentBrush}"
                             Background="{DynamicResource AppAccentMutedBrush}" />
              </StackPanel>
            </Border>
            <Button Classes="AccentAction"
                    HorizontalAlignment="Stretch"
                    IsVisible="{Binding LibraryBrowser.ShowExportAsEpubAction}"
                    Command="{Binding LibraryBrowser.ExportSelectedBookAsEpubCommand}">
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          HorizontalAlignment="Center">
                <PathIcon Classes="AppIconAccent"
                          Data="{StaticResource IconExport}" />
                <TextBlock VerticalAlignment="Center"
                           Text="Export as EPUB" />
              </StackPanel>
            </Button>
            <Border Classes="AppPanelMuted"
                    Padding="10"
                    IsVisible="{Binding LibraryBrowser.ShowExportAsEpubHint}">
              <TextBlock Classes="Caption"
                         Text="{Binding LibraryBrowser.ExportAsEpubHintText}"
                         TextWrapping="Wrap" />
            </Border>
            <Button Classes="SecondaryAction"
                    HorizontalAlignment="Stretch"
                    Command="{Binding LibraryBrowser.ExportSelectedBookCommand}">
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          HorizontalAlignment="Center">
                <PathIcon Classes="AppIconAccent"
                          Data="{StaticResource IconExport}" />
                <TextBlock VerticalAlignment="Center"
                           Text="Export" />
              </StackPanel>
            </Button>
            <Button Classes="DestructiveAction"
                    HorizontalAlignment="Stretch"
                    Command="{Binding LibraryBrowser.MoveSelectedBookToTrashCommand}">
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          HorizontalAlignment="Center">
                <PathIcon Data="{StaticResource IconTrash}"
                          Width="16"
                          Height="16"
                          Foreground="{DynamicResource AppDangerTextBrush}" />
                <TextBlock VerticalAlignment="Center"
                           Text="Move to Recycle Bin" />
              </StackPanel>
            </Button>
          </StackPanel>

        </Grid>
      </Border>

    </Grid>
  </Grid>
</UserControl>
