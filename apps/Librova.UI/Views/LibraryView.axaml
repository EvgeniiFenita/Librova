<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Librova.UI.ViewModels"
             x:Class="Librova.UI.Views.LibraryView"
             x:Name="LibraryRootView"
             x:DataType="viewModels:ShellViewModel"
             mc:Ignorable="d">
  <UserControl.Styles>
    <Style Selector="Border.LibraryToolbar">
      <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="20" />
    </Style>
    <Style Selector="Button.BookCardButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <ContentPresenter Content="{TemplateBinding Content}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Border.BookCard">
      <Setter Property="Background" Value="{DynamicResource AppSurfaceMutedBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Border.BookCardHoverChrome">
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Background" Value="#00FFFFFF" />
      <Setter Property="BorderBrush" Value="#00FFFFFF" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.BookCardButton:pointerover Border.BookCardHoverChrome:not(.Selected)">
      <Setter Property="Background" Value="#101A2330" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*"
        RowSpacing="18">
    <Border Classes="LibraryToolbar">
      <Grid ColumnDefinitions="2.3*,1.1*,Auto"
            ColumnSpacing="12">
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="10">
          <PathIcon Classes="AppIconAccent"
                    Width="20"
                    Height="20"
                    Data="{StaticResource IconSearch}"
                    VerticalAlignment="Center" />
          <TextBox Grid.Column="1"
                   Classes="AppTextInput"
                   Watermark="Search titles, authors, tags, and descriptions..."
                   Text="{Binding LibraryBrowser.SearchText, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
        <ComboBox Grid.Column="1"
                  Classes="AppComboBox"
                  SelectedItem="{Binding LibraryBrowser.SelectedLanguageFilter}"
                  ItemsSource="{Binding LibraryBrowser.AvailableLanguageFilters}" />
        <Border Grid.Column="2"
                Classes="MetricPill"
                MinWidth="138">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Text="{Binding LibraryBrowser.BookCountText}" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          ColumnDefinitions="*,Auto"
          ColumnSpacing="18">
      <Border Classes="AppPanelCompact"
              Padding="18">
        <Grid RowDefinitions="*">
          <Border Classes="AccentPanel"
                  IsVisible="{Binding LibraryBrowser.ShowEmptyState}">
            <StackPanel Spacing="12"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="420">
              <PathIcon Classes="AppIconAccent"
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Center"
                        Data="{StaticResource IconSearch}" />
              <TextBlock Classes="ViewTitle"
                         HorizontalAlignment="Center"
                         Text="{Binding LibraryBrowser.EmptyStateTitle}" />
              <TextBlock Classes="BodyMuted"
                         HorizontalAlignment="Center"
                         Text="{Binding LibraryBrowser.EmptyStateDescription}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <ScrollViewer x:Name="BooksViewport"
                        IsVisible="{Binding LibraryBrowser.HasBooks}"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Width="{Binding #BooksViewport.Bounds.Width}"
                        Spacing="4">
              <ItemsControl ItemsSource="{Binding LibraryBrowser.Books}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Classes="BookCardButton"
                            Width="184"
                            Height="314"
                            Margin="0,0,16,16"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Command="{Binding #LibraryRootView.DataContext.LibraryBrowser.SelectBookCommand}"
                            CommandParameter="{Binding .}">
                      <Border Classes="BookCard"
                              Height="314">
                        <Border.BorderBrush>
                          <Binding Path="CardBorderBrush" />
                        </Border.BorderBrush>
                        <Border.BorderThickness>
                          <Binding Path="CardBorderThickness" />
                        </Border.BorderThickness>
                        <Grid>
                          <Border Classes="BookCardHoverChrome"
                                  Classes.Selected="{Binding IsSelected}"
                                  IsHitTestVisible="False" />
                          <Grid Margin="12"
                                RowDefinitions="Auto,*"
                                RowSpacing="10">
                            <Border Classes="CoverMatte"
                                    Width="160"
                                    Height="240"
                                    HorizontalAlignment="Center"
                                    Background="{Binding CoverBackgroundBrush}">
                              <Grid>
                                <Image IsVisible="{Binding HasResolvedCover}"
                                       Source="{Binding ResolvedCoverImage}"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch" />
                                <TextBlock IsVisible="{Binding ShowCoverPlaceholder}"
                                           FontSize="42"
                                           FontWeight="Bold"
                                           Foreground="#E8F3FF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="{Binding CoverPlaceholderText}" />
                              </Grid>
                            </Border>
                            <TextBlock Grid.Row="1"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       MaxWidth="160"
                                       MinHeight="42"
                                       MaxHeight="42"
                                       Text="{Binding Title}"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis" />
                          </Grid>
                        </Grid>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <TextBlock HorizontalAlignment="Center"
                         Margin="0,0,0,8"
                         Classes="Caption"
                         IsVisible="{Binding LibraryBrowser.ShowLoadMoreIndicator}"
                         Text="Loading more books..." />
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Classes="AppPanelCompact"
              Width="380"
              Padding="18"
              HorizontalAlignment="Left"
              VerticalAlignment="Stretch"
              IsVisible="{Binding LibraryBrowser.ShowDetailsPanel}">
        <Grid RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="14">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="10">
            <StackPanel Spacing="4">
              <TextBlock Classes="SectionEyebrow"
                         Text="Selected Book" />
              <TextBlock Classes="SectionTitle"
                         Text="Selection Details" />
            </StackPanel>
            <Button Grid.Column="1"
                    Classes="IconAction"
                    Width="44"
                    Command="{Binding LibraryBrowser.CloseSelectionCommand}">
              <PathIcon Classes="AppIcon"
                        Data="{StaticResource IconClose}" />
            </Button>
          </Grid>

          <Grid Grid.Row="1"
                ColumnDefinitions="140,*"
                ColumnSpacing="14">
            <Border Classes="CoverMatte"
                    Width="140"
                    Height="210"
                    VerticalAlignment="Top"
                    Background="{Binding LibraryBrowser.SelectedBookCoverBackgroundBrush}">
              <Grid>
                <Image IsVisible="{Binding LibraryBrowser.HasSelectedBookCover}"
                       Source="{Binding LibraryBrowser.SelectedBookCoverImage}"
                       Stretch="Uniform"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch" />
                <TextBlock IsVisible="{Binding LibraryBrowser.ShowSelectedBookCoverPlaceholder}"
                           FontSize="64"
                           FontWeight="Bold"
                           Foreground="#E8F3FF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="{Binding LibraryBrowser.SelectedBookCoverPlaceholderText}" />
              </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        Spacing="8">
              <TextBlock Classes="ViewTitle"
                         Text="{Binding LibraryBrowser.SelectedBookTitle}"
                         TextWrapping="Wrap" />
              <TextBlock Classes="BodyMuted"
                         FontSize="15"
                         Text="{Binding LibraryBrowser.SelectedBookAuthorText}"
                         TextWrapping="Wrap" />
              <TextBlock IsVisible="{Binding LibraryBrowser.ShowDetailsPanelLoading}"
                         Classes="Caption"
                         Text="Loading details..." />

              <ItemsControl ItemsSource="{Binding LibraryBrowser.SelectedBookMetadataPairs}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="10"
                          Margin="0,0,0,6">
                      <TextBlock Classes="MetaLabel"
                                 Text="{Binding Label}" />
                      <TextBlock Grid.Column="1"
                                 Classes="BodyMuted"
                                 Text="{Binding Value}"
                                 TextWrapping="Wrap" />
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Grid>

          <ScrollViewer Grid.Row="2"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="14">
              <StackPanel Spacing="6">
                <TextBlock Classes="MetaLabel"
                           Text="Annotation" />
                <Border Classes="AppPanelMuted"
                        Padding="12">
                  <TextBlock Classes="BodyMuted"
                             Text="{Binding LibraryBrowser.SelectedBookAnnotationText}"
                             TextWrapping="Wrap" />
                </Border>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>

          <StackPanel Grid.Row="3"
                      Spacing="10">
            <Button Classes="AccentAction"
                    HorizontalAlignment="Stretch"
                    IsVisible="{Binding LibraryBrowser.ShowExportAsEpubAction}"
                    Command="{Binding LibraryBrowser.ExportSelectedBookAsEpubCommand}">
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="10">
                <PathIcon Classes="AppIconAccent"
                          Data="{StaticResource IconExport}" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="Export As EPUB" />
              </Grid>
            </Button>
            <Border Classes="AppPanelMuted"
                    Padding="12"
                    IsVisible="{Binding LibraryBrowser.ShowExportAsEpubHint}">
              <TextBlock Classes="Caption"
                         Text="{Binding LibraryBrowser.ExportAsEpubHintText}"
                         TextWrapping="Wrap" />
            </Border>
            <Button Classes="SecondaryAction"
                    HorizontalAlignment="Stretch"
                    Command="{Binding LibraryBrowser.ExportSelectedBookCommand}">
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="10">
                <PathIcon Classes="AppIconAccent"
                          Data="{StaticResource IconExport}" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="Export" />
              </Grid>
            </Button>
            <Button Classes="DestructiveAction"
                    HorizontalAlignment="Stretch"
                    Command="{Binding LibraryBrowser.MoveSelectedBookToTrashCommand}">
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="10">
                <PathIcon Classes="AppIcon"
                          Foreground="#FFE8E8"
                          Data="{StaticResource IconTrash}" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="#FFE8E8"
                           Text="Move To Trash" />
              </Grid>
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
