<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:Librova.UI.ViewModels"
        xmlns:views="using:Librova.UI.Views"
        x:Class="Librova.UI.Views.MainWindow"
        x:DataType="viewModels:ShellWindowViewModel"
        Width="1240"
        Height="820"
        Icon="/Assets/librova.ico"
        DragDrop.AllowDrop="True"
        mc:Ignorable="d">
  <Grid Margin="26">
    <Border Classes="AppPanel"
            IsVisible="{Binding IsStartingUp}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">
          <TextBlock Classes="SectionEyebrow"
                     Text="Launching" />
          <TextBlock Classes="DisplayTitle"
                     Text="Librova is starting" />
          <TextBlock FontSize="16"
                     FontWeight="SemiBold"
                     Text="{Binding StatusText}" />
          <TextBlock Classes="BodyMuted"
                     MaxWidth="760"
                     FontSize="15"
                     Text="{Binding StartupGuidanceText}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Classes="AppPanel"
            IsVisible="{Binding IsShowingFirstRunSetup}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="22">
          <StackPanel Spacing="10">
            <TextBlock Classes="SectionEyebrow"
                       Text="First Launch" />
            <TextBlock Classes="DisplayTitle"
                       Text="Set up your Librova library" />
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Text="{Binding StatusText}" />
          </StackPanel>

          <Border Classes="AccentPanel">
            <StackPanel Spacing="14">
              <TextBlock Classes="SectionTitle"
                         Text="Managed Library Root" />
              <TextBlock Classes="BodyMuted"
                         Text="Librova will store the database, managed books, covers, logs, temporary import files, and trash under this root."
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                <TextBox Classes="AppTextInput"
                         Watermark="C:\Libraries\Librova"
                         Text="{Binding Setup.LibraryRoot}" />
                <Button Grid.Column="1"
                        Classes="SecondaryAction"
                        MinWidth="108"
                        Command="{Binding Setup.BrowseLibraryRootCommand}"
                        Content="Browse..." />
              </Grid>
              <TextBlock FontSize="12"
                         Foreground="{DynamicResource AppWarningBrush}"
                         IsVisible="{Binding Setup.HasValidationError}"
                         Text="{Binding Setup.ValidationMessage}"
                         TextWrapping="Wrap" />
              <TextBlock Classes="Caption"
                         IsVisible="{Binding Setup.ShowHelperText}"
                         Text="Choose an absolute directory path. The folder may be new; Librova will create its managed structure on first launch."
                         TextWrapping="Wrap" />
              <WrapPanel ItemWidth="160"
                         ItemHeight="44">
                <Button Classes="PrimaryAction"
                        Width="180"
                        Command="{Binding Setup.ContinueCommand}"
                        Content="Continue" />
              </WrapPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border Classes="DangerPanel"
            IsVisible="{Binding HasStartupError}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">
          <TextBlock Classes="SectionEyebrow"
                     Text="Recovery" />
          <TextBlock Classes="DisplayTitle"
                     Text="Librova startup failed" />
          <TextBlock FontSize="16"
                     FontWeight="SemiBold"
                     Text="{Binding StatusText}" />
          <TextBlock MaxWidth="760"
                     FontSize="15"
                     Text="{Binding StartupError}"
                     TextWrapping="Wrap" />
          <Border Classes="AppPanelMuted">
            <StackPanel Spacing="10">
              <TextBlock FontWeight="SemiBold"
                         Text="What to do next" />
              <TextBlock Classes="BodyMuted"
                         Text="{Binding StartupGuidanceText}"
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="10"
                    RowDefinitions="Auto,Auto,Auto">
                <TextBlock FontWeight="SemiBold"
                           Text="UI log" />
                <TextBlock Grid.Column="1"
                           Classes="BodyMuted"
                           Text="{Binding UiLogFilePath}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="1"
                           FontWeight="SemiBold"
                           Text="UI state" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Classes="BodyMuted"
                           Text="{Binding UiStateFilePath}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="2"
                           FontWeight="SemiBold"
                           Text="Preferences" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Classes="BodyMuted"
                           Text="{Binding UiPreferencesFilePath}"
                           TextWrapping="Wrap" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="AccentPanel"
                  IsVisible="{Binding HasStartupRecoverySetup}">
            <StackPanel Spacing="14">
              <TextBlock Classes="SectionTitle"
                         Text="Choose Another Library Root" />
              <TextBlock Classes="BodyMuted"
                         Text="If startup failed because the configured library root is unavailable or invalid, pick a different managed library root and retry startup from here."
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                <TextBox Classes="AppTextInput"
                         Watermark="C:\Libraries\Librova"
                         Text="{Binding Setup.LibraryRoot}" />
                <Button Grid.Column="1"
                        Classes="SecondaryAction"
                        MinWidth="108"
                        Command="{Binding Setup.BrowseLibraryRootCommand}"
                        Content="Browse..." />
              </Grid>
              <TextBlock FontSize="12"
                         Foreground="{DynamicResource AppWarningBrush}"
                         IsVisible="{Binding Setup.HasValidationError}"
                         Text="{Binding Setup.ValidationMessage}"
                         TextWrapping="Wrap" />
              <TextBlock Classes="Caption"
                         IsVisible="{Binding Setup.ShowHelperText}"
                         Text="{Binding Setup.HelperText}"
                         TextWrapping="Wrap" />
              <WrapPanel>
                <Button Classes="PrimaryAction"
                        Width="220"
                        Command="{Binding Setup.ContinueCommand}"
                        Content="Retry With This Library" />
              </WrapPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid IsVisible="{Binding HasShell}"
          ColumnDefinitions="268,*"
          ColumnSpacing="20">
      <Border Grid.Column="0"
              Classes="AppPanel">
        <Grid RowDefinitions="Auto,Auto,*,Auto"
              RowSpacing="18">
          <StackPanel Spacing="10">
            <TextBlock Classes="SectionEyebrow"
                       Text="Desktop Library Manager" />
            <TextBlock Classes="DisplayTitle"
                       Text="Librova" />
            <TextBlock Classes="BodyMuted"
                       Text="A personal desktop library for your books."
                       TextWrapping="Wrap" />
          </StackPanel>

          <StackPanel Grid.Row="1"
                      Spacing="10">
            <Button Classes="NavItem"
                    Classes.Active="{Binding Shell.IsLibrarySectionActive}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding Shell.ShowLibrarySectionCommand}">
              <Grid ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="12">
                <PathIcon Classes="AppIcon"
                          Data="{StaticResource IconLibrary}" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="Library" />
                <PathIcon Grid.Column="2"
                          Classes="AppIcon"
                          Data="{StaticResource IconChevronRight}" />
              </Grid>
            </Button>
            <Button Classes="NavItem"
                    Classes.Active="{Binding Shell.IsImportSectionActive}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding Shell.ShowImportSectionCommand}">
              <Grid ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="12">
                <PathIcon Classes="AppIcon"
                          Data="{StaticResource IconImport}" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="Import" />
                <PathIcon Grid.Column="2"
                          Classes="AppIcon"
                          Data="{StaticResource IconChevronRight}" />
              </Grid>
            </Button>
          </StackPanel>

          <Border Grid.Row="2"
                  Classes="AppPanelMuted">
            <StackPanel Spacing="12">
              <TextBlock Classes="SectionEyebrow"
                         Text="Current Library" />
              <TextBlock Classes="Caption"
                         Text="{Binding Shell.LibraryRoot}"
                         TextWrapping="Wrap" />
              <TextBlock FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource AppTextSecondaryBrush}"
                         Text="{Binding Shell.CurrentLibraryStatisticsText}"
                         TextWrapping="Wrap" />
              <Button Classes="SecondaryAction"
                      HorizontalAlignment="Stretch"
                      Command="{Binding Shell.OpenLibraryCommand}">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                  <PathIcon Classes="AppIconAccent"
                            Data="{StaticResource IconFolderOpen}" />
                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             Text="Open Library..." />
                </Grid>
              </Button>
              <Button Classes="SecondaryAction"
                      HorizontalAlignment="Stretch"
                      Command="{Binding Shell.CreateLibraryCommand}">
                <Grid ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                  <PathIcon Classes="AppIconAccent"
                            Data="{StaticResource IconAddFolder}" />
                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             Text="Create Library..." />
                </Grid>
              </Button>
            </StackPanel>
          </Border>

          <Button Grid.Row="3"
                  Classes="NavItem"
                  Classes.Active="{Binding Shell.IsSettingsSectionActive}"
                  HorizontalAlignment="Stretch"
                  Command="{Binding Shell.ShowSettingsSectionCommand}">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="12">
              <PathIcon Classes="AppIcon"
                        Data="{StaticResource IconSettings}" />
              <TextBlock Grid.Column="1"
                         VerticalAlignment="Center"
                         Text="Settings" />
              <PathIcon Grid.Column="2"
                        Classes="AppIcon"
                        Data="{StaticResource IconChevronRight}" />
            </Grid>
          </Button>
        </Grid>
      </Border>

      <Grid Grid.Column="1"
            DataContext="{Binding Shell}">
        <views:LibraryView IsVisible="{Binding IsLibrarySectionActive}" />
        <views:ImportView IsVisible="{Binding IsImportSectionActive}" />
        <views:SettingsView IsVisible="{Binding IsSettingsSectionActive}" />
      </Grid>
    </Grid>
  </Grid>
</Window>
