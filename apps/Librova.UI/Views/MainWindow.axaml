<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:Librova.UI.ViewModels"
        xmlns:views="using:Librova.UI.Views"
        x:Class="Librova.UI.Views.MainWindow"
        x:DataType="viewModels:ShellWindowViewModel"
        Width="1240"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        DragDrop.AllowDrop="True"
        Background="#E9E1D6"
        Foreground="#211B17"
        mc:Ignorable="d">
  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.SectionTitle">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#2A241F" />
    </Style>
    <Style Selector="Border.SurfaceCard">
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="22" />
      <Setter Property="Background" Value="#FFF9F1" />
      <Setter Property="BorderBrush" Value="#D8CCBD" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Border.TintedCard">
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="22" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.PrimaryAction">
      <Setter Property="Background" Value="#BA5A2A" />
      <Setter Property="Foreground" Value="#FFF9F1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="CornerRadius" Value="14" />
    </Style>
    <Style Selector="Button.SecondaryAction">
      <Setter Property="Background" Value="#E7DDD1" />
      <Setter Property="Foreground" Value="#2F2822" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="CornerRadius" Value="14" />
    </Style>
    <Style Selector="TextBox.ImportField">
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Background" Value="#FFFDFC" />
    </Style>
  </Window.Styles>

  <Grid Margin="26">
    <Border IsVisible="{Binding IsStartingUp}"
            Background="#FFF8EF"
            BorderBrush="#D9C7AE"
            BorderThickness="1"
            CornerRadius="28"
            Padding="30">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14">
          <TextBlock FontSize="34"
                     FontWeight="Bold"
                     Text="Librova is starting" />
          <TextBlock FontSize="16"
                     FontWeight="SemiBold"
                     Text="{Binding StatusText}" />
          <TextBlock MaxWidth="760"
                     FontSize="15"
                     Text="{Binding StartupGuidanceText}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border IsVisible="{Binding IsShowingFirstRunSetup}"
            Background="#FFF8EF"
            BorderBrush="#D9C7AE"
            BorderThickness="1"
            CornerRadius="28"
            Padding="30">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">
          <StackPanel Spacing="10">
            <TextBlock FontSize="34"
                       FontWeight="Bold"
                       Text="Set up your Librova library" />
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Text="{Binding StatusText}" />
          </StackPanel>

          <Border Background="#FFF9F1"
                  BorderBrush="#E0CAB4"
                  BorderThickness="1"
                  CornerRadius="20"
                  Padding="20">
            <StackPanel Spacing="14">
              <TextBlock Classes="SectionTitle"
                         Text="Managed Library Root" />
              <TextBlock Opacity="0.74"
                         Text="Librova will store the database, managed books, covers, logs, temporary import files, and trash under this root."
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                <TextBox Classes="ImportField"
                         Watermark="C:\Libraries\Librova"
                         Text="{Binding Setup.LibraryRoot}" />
                <Button Grid.Column="1"
                        Classes="SecondaryAction"
                        MinWidth="108"
                        Command="{Binding Setup.BrowseLibraryRootCommand}"
                        Content="Browse..." />
              </Grid>
              <TextBlock FontSize="12"
                         Foreground="#A04628"
                         IsVisible="{Binding Setup.HasValidationError}"
                         Text="{Binding Setup.ValidationMessage}"
                         TextWrapping="Wrap" />
              <TextBlock FontSize="12"
                         Opacity="0.64"
                         IsVisible="{Binding Setup.ShowHelperText}"
                         Text="Choose an absolute directory path. The folder may be new; Librova will create its managed structure on first launch."
                         TextWrapping="Wrap" />
              <WrapPanel ItemWidth="160"
                         ItemHeight="44">
                <Button Classes="PrimaryAction"
                        Width="180"
                        Command="{Binding Setup.ContinueCommand}"
                        Content="Continue" />
              </WrapPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Border IsVisible="{Binding HasStartupError}"
            Background="#FFF4EC"
            BorderBrush="#D97C49"
            BorderThickness="1"
            CornerRadius="28"
            Padding="30">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14">
          <TextBlock FontSize="34"
                     FontWeight="Bold"
                     Text="Librova startup failed" />
          <TextBlock FontSize="16"
                     FontWeight="SemiBold"
                     Text="{Binding StatusText}" />
          <TextBlock MaxWidth="760"
                     FontSize="15"
                     Text="{Binding StartupError}"
                     TextWrapping="Wrap" />
          <Border Background="#FFF9F1"
                  BorderBrush="#E0CAB4"
                  BorderThickness="1"
                  CornerRadius="18"
                  Padding="18">
            <StackPanel Spacing="10">
              <TextBlock FontWeight="SemiBold"
                         Text="What to do next" />
              <TextBlock Text="{Binding StartupGuidanceText}"
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="10"
                    RowDefinitions="Auto,Auto,Auto">
                <TextBlock FontWeight="SemiBold"
                           Text="UI log" />
                <TextBlock Grid.Column="1"
                           Text="{Binding UiLogFilePath}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="1"
                           FontWeight="SemiBold"
                           Text="UI state" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding UiStateFilePath}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="2"
                           FontWeight="SemiBold"
                           Text="Preferences" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding UiPreferencesFilePath}"
                           TextWrapping="Wrap" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Background="#FFF9F1"
                  BorderBrush="#E0CAB4"
                  BorderThickness="1"
                  CornerRadius="20"
                  Padding="20"
                  IsVisible="{Binding HasStartupRecoverySetup}">
            <StackPanel Spacing="14">
              <TextBlock Classes="SectionTitle"
                         Text="Choose Another Library Root" />
              <TextBlock Opacity="0.74"
                         Text="If startup failed because the configured library root is unavailable or invalid, pick a different managed library root and retry startup from here."
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                <TextBox Classes="ImportField"
                         Watermark="C:\Libraries\Librova"
                         Text="{Binding Setup.LibraryRoot}" />
                <Button Grid.Column="1"
                        Classes="SecondaryAction"
                        MinWidth="108"
                        Command="{Binding Setup.BrowseLibraryRootCommand}"
                        Content="Browse..." />
              </Grid>
              <TextBlock FontSize="12"
                         Foreground="#A04628"
                         IsVisible="{Binding Setup.HasValidationError}"
                         Text="{Binding Setup.ValidationMessage}"
                         TextWrapping="Wrap" />
              <TextBlock FontSize="12"
                         Opacity="0.64"
                         IsVisible="{Binding Setup.ShowHelperText}"
                         Text="{Binding Setup.HelperText}"
                         TextWrapping="Wrap" />
              <WrapPanel>
                <Button Classes="PrimaryAction"
                        Width="220"
                        Command="{Binding Setup.ContinueCommand}"
                        Content="Retry With This Library" />
              </WrapPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid IsVisible="{Binding HasShell}"
          ColumnDefinitions="250,*"
          ColumnSpacing="20">
      <Border Grid.Column="0"
              Background="#DCCBB8"
              CornerRadius="28"
              Padding="22">
        <StackPanel Spacing="18">
          <StackPanel Spacing="8">
            <TextBlock FontSize="34"
                       FontWeight="Bold"
                       Text="Librova" />
            <TextBlock Opacity="0.78"
                       Text="A focused desktop library manager over the native core."
                       TextWrapping="Wrap" />
          </StackPanel>

          <StackPanel Spacing="10">
            <Button Classes="SecondaryAction"
                    HorizontalAlignment="Stretch"
                    Command="{Binding Shell.ShowLibrarySectionCommand}"
                    Content="Library" />
            <Button Classes="SecondaryAction"
                    HorizontalAlignment="Stretch"
                    Command="{Binding Shell.ShowImportSectionCommand}"
                    Content="Import" />
            <Button Classes="SecondaryAction"
                    HorizontalAlignment="Stretch"
                    Command="{Binding Shell.ShowSettingsSectionCommand}"
                    Content="Settings" />
          </StackPanel>

          <Border Background="#FFF8EF"
                  CornerRadius="18"
                  Padding="16">
            <StackPanel Spacing="10">
              <TextBlock FontWeight="SemiBold"
                         Text="Current Library" />
              <TextBlock FontSize="12"
                         Text="{Binding Shell.LibraryRoot}"
                         TextWrapping="Wrap" />
              <Button Classes="SecondaryAction"
                      HorizontalAlignment="Stretch"
                      Command="{Binding Shell.OpenLibraryCommand}"
                      Content="Open Library..." />
              <Button Classes="SecondaryAction"
                      HorizontalAlignment="Stretch"
                      Command="{Binding Shell.CreateLibraryCommand}"
                      Content="Create Library..." />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Grid Grid.Column="1"
            DataContext="{Binding Shell}">
        <views:LibraryView IsVisible="{Binding IsLibrarySectionActive}" />
        <views:ImportView IsVisible="{Binding IsImportSectionActive}" />
        <views:SettingsView IsVisible="{Binding IsSettingsSectionActive}" />
      </Grid>
    </Grid>
  </Grid>
</Window>
