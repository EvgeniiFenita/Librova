<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:Librova.UI.ViewModels"
        xmlns:views="using:Librova.UI.Views"
        x:Class="Librova.UI.Views.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="viewModels:ShellWindowViewModel"
        Width="1280"
        Height="840"
        Icon="/Assets/librova.ico"
        Background="{DynamicResource AppBackgroundBrush}"
        DragDrop.AllowDrop="True"
        KeyDown="OnWindowKeyDown"
        mc:Ignorable="d">

  <Window.Resources>
    <!-- Thin scrollbar in its own Grid column so it never overlaps content.
         Column is Auto → collapses to 0 when scrollbar is hidden (no overflow),
         giving full-width buttons. When overflow: 5px column, no overlap. -->
    <ControlTheme x:Key="OverlayScrollViewerTheme" TargetType="ScrollViewer">
      <Setter Property="Template">
        <ControlTemplate>
          <Grid ColumnDefinitions="*,Auto">
            <ScrollContentPresenter x:Name="PART_ContentPresenter"
                                    Padding="{TemplateBinding Padding}"
                                    IsScrollChainingEnabled="{TemplateBinding IsScrollChainingEnabled}" />
            <ScrollBar x:Name="PART_VerticalScrollBar"
                       Grid.Column="1"
                       Classes="OverlayBar"
                       Width="5"
                       Margin="3,0,0,0"
                       Orientation="Vertical"
                       AllowAutoHide="{TemplateBinding AllowAutoHide}" />
          </Grid>
        </ControlTemplate>
      </Setter>
    </ControlTheme>
  </Window.Resources>

  <!-- Full-bleed root — no outer margin so the app surface fills the whole window -->
  <Grid>

    <!-- ── STARTUP ──────────────────────────────────────────── -->
    <Border Background="{DynamicResource AppSurfaceBrush}"
            IsVisible="{Binding IsStartingUp}">
      <StackPanel Spacing="14"
                  Margin="40,32">
        <Border Background="{DynamicResource AppAccentSurfaceBrush}"
                BorderBrush="{DynamicResource AppAccentBorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Radius.Small}"
                HorizontalAlignment="Left"
                Padding="10,8">
          <StackPanel Orientation="Horizontal"
                      Spacing="10">
            <PathIcon Classes="AppIconAccent"
                      Width="22"
                      Height="22"
                      Data="{StaticResource IconBook}" />
            <TextBlock FontSize="20"
                       FontWeight="Bold"
                       Text="Librova" />
          </StackPanel>
        </Border>
        <TextBlock Classes="SectionEyebrow"
                   Text="LAUNCHING" />
        <TextBlock Classes="DisplayTitle"
                   Text="Librova is starting" />
        <TextBlock FontSize="15"
                   FontWeight="SemiBold"
                   Text="{Binding StatusText}" />
        <TextBlock Classes="BodyMuted"
                   MaxWidth="680"
                   FontSize="14"
                   Text="{Binding StartupGuidanceText}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <!-- ── FIRST RUN SETUP ──────────────────────────────────── -->
    <Border Background="{DynamicResource AppSurfaceBrush}"
            IsVisible="{Binding IsShowingFirstRunSetup}">
      <Grid ColumnDefinitions="260,*"
            ColumnSpacing="0">

        <!-- Left: decorative hero panel (full-height, icon centred) -->
        <Border Grid.Column="0"
                Background="{DynamicResource AppAccentSurfaceBrush}"
                BorderBrush="{DynamicResource AppAccentBorderBrush}"
                BorderThickness="0,0,1,0">
          <StackPanel VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="20"
                      Margin="32">
            <PathIcon Foreground="{DynamicResource AppAccentBrush}"
                      Width="100"
                      Height="100"
                      HorizontalAlignment="Center"
                      Data="{StaticResource IconLibrary}" />
            <StackPanel Spacing="6"
                        HorizontalAlignment="Center">
              <TextBlock FontSize="22"
                         FontWeight="Bold"
                         LineHeight="30"
                         HorizontalAlignment="Center"
                         Text="Librova" />
              <TextBlock Classes="Caption"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         Text="Your shelf, your story"
                         TextWrapping="Wrap" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Right: setup form with its own scroll -->
        <ScrollViewer Grid.Column="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="24"
                      Margin="40,40"
                      MaxWidth="480">
            <StackPanel Spacing="8">
              <TextBlock Classes="SectionEyebrow"
                         Text="WELCOME" />
              <TextBlock Classes="DisplayTitle"
                         Text="Set up your library" />
              <TextBlock Classes="BodyMuted"
                         Text="{Binding StatusText}" />
            </StackPanel>

            <Border Classes="AccentPanel">
              <StackPanel Spacing="14">
                <TextBlock Classes="SectionTitle"
                           Text="Library Root Folder" />
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      IsVisible="{Binding Setup.ShowLibraryOpenModeSelector}">
                  <Button Classes="OptionCard"
                          Classes.Active="{Binding Setup.IsCreateLibraryModeSelected}"
                          Command="{Binding Setup.SelectCreateLibraryModeCommand}">
                    <StackPanel Spacing="10">
                      <PathIcon Data="{StaticResource IconAddFolder}"
                                Width="22"
                                Height="22" />
                      <TextBlock Classes="OptionCardTitle"
                                 Text="Create New" />
                      <TextBlock Classes="Caption"
                                 Text="Start a fresh library in a new or empty folder."
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Button>
                  <Button Grid.Column="1"
                          Classes="OptionCard"
                          Classes.Active="{Binding Setup.IsOpenLibraryModeSelected}"
                          Command="{Binding Setup.SelectOpenLibraryModeCommand}">
                    <StackPanel Spacing="10">
                      <PathIcon Data="{StaticResource IconFolderOpen}"
                                Width="22"
                                Height="22" />
                      <TextBlock Classes="OptionCardTitle"
                                 Text="Open Existing" />
                      <TextBlock Classes="Caption"
                                 Text="Point to a folder that already contains a Librova library."
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Button>
                </Grid>
                <TextBlock Classes="BodyMuted"
                           Text="Librova will store the database, managed books, covers, logs, temporary import files, and trash under this root."
                           TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                  <TextBox Classes="AppTextInput"
                           PlaceholderText="C:\Libraries\Librova"
                           Text="{Binding Setup.LibraryRoot}" />
                  <Button Grid.Column="1"
                          Classes="SecondaryAction"
                          MinWidth="110"
                          Command="{Binding Setup.BrowseLibraryRootCommand}"
                          Content="Browse..." />
                </Grid>
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource AppWarningBrush}"
                           IsVisible="{Binding Setup.HasValidationError}"
                           Text="{Binding Setup.ValidationMessage}"
                           TextWrapping="Wrap" />
                <TextBlock Classes="Caption"
                           IsVisible="{Binding Setup.ShowHelperText}"
                           Text="{Binding Setup.HelperText}"
                           TextWrapping="Wrap" />
                <Button Classes="PrimaryAction"
                        Width="180"
                        HorizontalAlignment="Left"
                        Command="{Binding Setup.ContinueCommand}"
                        Content="{Binding Setup.ContinueButtonText}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>

      </Grid>
    </Border>

    <!-- ── STARTUP ERROR ────────────────────────────────────── -->
    <Border Background="{DynamicResource AppDangerSurfaceBrush}"
            BorderBrush="{DynamicResource AppDangerBorderBrush}"
            BorderThickness="0,0,0,2"
            IsVisible="{Binding HasStartupError}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18"
                    Margin="40,32"
                    MaxWidth="820">
          <TextBlock Classes="SectionEyebrow"
                     Text="RECOVERY" />
          <TextBlock Classes="DisplayTitle"
                     Text="Startup failed" />
          <TextBlock FontSize="15"
                     FontWeight="SemiBold"
                     Text="{Binding StatusText}" />
          <TextBlock FontSize="14"
                     Text="{Binding StartupError}"
                     TextWrapping="Wrap" />

          <Border Classes="AppPanelMuted">
            <StackPanel Spacing="10">
              <TextBlock Classes="SectionTitle"
                         Text="What to do next" />
              <TextBlock Classes="BodyMuted"
                         Text="{Binding StartupGuidanceText}"
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="Auto,*"
                    ColumnSpacing="16"
                    RowDefinitions="Auto,Auto,Auto">
                <TextBlock Classes="MetaLabel"
                           Text="UI LOG" />
                <TextBlock Grid.Column="1"
                           Classes="BodyMuted"
                           Text="{Binding UiLogFilePath}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="1"
                           Classes="MetaLabel"
                           Text="UI STATE" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Classes="BodyMuted"
                           Text="{Binding UiStateFilePath}"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="2"
                           Classes="MetaLabel"
                           Text="PREFERENCES" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Classes="BodyMuted"
                           Text="{Binding UiPreferencesFilePath}"
                           TextWrapping="Wrap" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="AccentPanel"
                  IsVisible="{Binding HasStartupRecoverySetup}">
            <StackPanel Spacing="14">
              <TextBlock Classes="SectionTitle"
                         Text="Choose Another Library Root" />
              <TextBlock Classes="BodyMuted"
                         Text="If startup failed because the configured library root is unavailable or invalid, pick a different managed library root and retry startup from here."
                         TextWrapping="Wrap" />
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                <TextBox Classes="AppTextInput"
                         PlaceholderText="C:\Libraries\Librova"
                         Text="{Binding Setup.LibraryRoot}" />
                <Button Grid.Column="1"
                        Classes="SecondaryAction"
                        MinWidth="110"
                        Command="{Binding Setup.BrowseLibraryRootCommand}"
                        Content="Browse..." />
              </Grid>
              <TextBlock FontSize="12"
                         Foreground="{DynamicResource AppWarningBrush}"
                         IsVisible="{Binding Setup.HasValidationError}"
                         Text="{Binding Setup.ValidationMessage}"
                         TextWrapping="Wrap" />
              <TextBlock Classes="Caption"
                         IsVisible="{Binding Setup.ShowHelperText}"
                         Text="{Binding Setup.HelperText}"
                         TextWrapping="Wrap" />
              <Button Classes="PrimaryAction"
                      Width="240"
                      HorizontalAlignment="Left"
                      Command="{Binding Setup.ContinueCommand}"
                      Content="Retry With This Library" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ── MAIN SHELL ────────────────────────────────────────── -->
    <!--
         Full-bleed two-column layout.
         Left column = sidebar (darker bg), right = content (surface bg).
         No outer wrapper — avoids the "floating card in black window" look.
    -->
    <Grid IsVisible="{Binding HasShell}"
          ColumnDefinitions="244,*">

      <!-- Sidebar background fill -->
      <Border Grid.Column="0"
              Background="{DynamicResource AppSidebarGradientBrush}" />

      <!-- Sidebar / content 1 px divider -->
      <Rectangle Grid.Column="0"
                 Width="1"
                 HorizontalAlignment="Right"
                 Fill="{DynamicResource AppBorderBrush}" />

      <!-- ── SIDEBAR CONTENT ─────────────────────────────── -->
      <Border Grid.Column="0"
              Padding="14,18">
        <!--
         DockPanel layout:
               · Bottom-docked section = library info card + Settings button + version
               · Fill section (top)    = branding + primary nav
             This keeps nav tightly below branding with no artificial gap,
             and anchors library/settings to the bottom of the sidebar.
        -->
        <DockPanel>

          <!-- Bottom: library card + settings + version -->
          <StackPanel DockPanel.Dock="Bottom"
                      Spacing="5">
            <Border Classes="AppPanelMuted"
                    IsEnabled="{Binding Shell.IsImportInProgress, Converter={x:Static BoolConverters.Not}}"
                    Padding="12">
              <StackPanel Spacing="8">
                <TextBlock Classes="SectionEyebrow"
                           Text="LIBRARY" />
                <TextBlock Classes="Caption"
                           Text="{Binding Shell.LibraryRoot}"
                           TextWrapping="Wrap" />
                <TextBlock Classes="Caption"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextSecondaryBrush}"
                           Text="{Binding Shell.CurrentLibraryStatisticsText}"
                           TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="6">
                  <Button Grid.Column="0"
                          Classes="SecondaryAction"
                          HorizontalAlignment="Stretch"
                          Padding="8,0"
                          Command="{Binding Shell.OpenLibraryCommand}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                HorizontalAlignment="Center">
                      <PathIcon Classes="AppIconAccent"
                                Width="13"
                                Height="13"
                                Data="{StaticResource IconFolderOpen}" />
                      <TextBlock VerticalAlignment="Center"
                                 FontSize="12"
                                 Text="Open" />
                    </StackPanel>
                  </Button>
                  <Button Grid.Column="1"
                          Classes="SecondaryAction"
                          HorizontalAlignment="Stretch"
                          Padding="8,0"
                          Command="{Binding Shell.CreateLibraryCommand}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6"
                                HorizontalAlignment="Center">
                      <PathIcon Classes="AppIconAccent"
                                Width="13"
                                Height="13"
                                Data="{StaticResource IconAddFolder}" />
                      <TextBlock VerticalAlignment="Center"
                                 FontSize="12"
                                 Text="New" />
                    </StackPanel>
                  </Button>
                </Grid>
              </StackPanel>
            </Border>

            <Button Classes="NavItem"
                    Classes.Active="{Binding Shell.IsSettingsNavigationActive}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding Shell.ShowSettingsSectionCommand}">
              <StackPanel Orientation="Horizontal"
                          Spacing="10">
                <PathIcon Classes="AppIcon"
                          Data="{StaticResource IconSettings}" />
                <TextBlock Classes="NavLabel"
                           VerticalAlignment="Center"
                           Text="Settings" />
              </StackPanel>
            </Button>

            <!-- App version — shown only when shell is running -->
            <TextBlock HorizontalAlignment="Center"
                       Margin="0,6,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource AppTextMutedBrush}"
                       IsVisible="{Binding HasShell}"
                       Text="{Binding Shell.ApplicationVersionText}" />
          </StackPanel>

          <!-- Top: branding + primary nav (fills remaining space) -->
          <StackPanel Spacing="4"
                      Classes.Lockout="{Binding Shell.IsImportInProgress}">
            <!-- App identity -->
            <Border Background="{DynamicResource AppAccentSurfaceBrush}"
                    BorderBrush="{DynamicResource AppAccentBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource Radius.Small}"
                    Padding="10,8">
              <StackPanel Orientation="Horizontal"
                          Spacing="10"
                          VerticalAlignment="Center">
                <PathIcon Classes="AppIconAccent"
                          Width="22"
                          Height="22"
                          VerticalAlignment="Center"
                          Data="{StaticResource IconBook}" />
                <TextBlock FontSize="20"
                           FontWeight="Bold"
                           LineHeight="28"
                           VerticalAlignment="Center"
                           Text="Librova" />
              </StackPanel>
            </Border>
            <TextBlock Classes="Caption"
                       Margin="4,0,0,0"
                       Text="Your shelf, your story" />

            <!-- Primary nav -->
            <StackPanel Spacing="5"
                        Margin="0,18,0,0">
              <Button Classes="NavItem"
                      Classes.Active="{Binding Shell.IsLibraryNavigationActive}"
                      HorizontalAlignment="Stretch"
                      Command="{Binding Shell.ShowLibrarySectionCommand}">
                <StackPanel Orientation="Horizontal"
                            Spacing="10">
                  <PathIcon Classes="AppIcon"
                            Data="{StaticResource IconLibrary}" />
                  <TextBlock Classes="NavLabel"
                             VerticalAlignment="Center"
                             Text="Library" />
                </StackPanel>
              </Button>
              <Button Classes="NavItem"
                      Classes.Active="{Binding Shell.IsImportNavigationActive}"
                      HorizontalAlignment="Stretch"
                      Command="{Binding Shell.ShowImportSectionCommand}">
                <StackPanel Orientation="Horizontal"
                            Spacing="10">
                  <PathIcon Classes="AppIcon"
                            Data="{StaticResource IconImport}" />
                  <TextBlock Classes="NavLabel"
                             VerticalAlignment="Center"
                             Text="Import" />
                </StackPanel>
              </Button>

              <Border Classes="AppPanelMuted"
                      Margin="0,8,0,0"
                      Padding="8">
                <StackPanel Spacing="8">
                  <TextBlock Classes="SectionEyebrow"
                             Text="COLLECTIONS" />
                  <StackPanel IsVisible="{Binding Shell.LibraryBrowser.HasCollections, Converter={x:Static BoolConverters.Not}}"
                              HorizontalAlignment="Center"
                              Margin="0,4,0,4"
                              Spacing="4">
                    <TextBlock FontSize="26"
                               LineHeight="34"
                               HorizontalAlignment="Center"
                               Text="📚" />
                    <TextBlock Classes="Caption"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Text="No collections yet" />
                    <Button Classes="CollectionLinkAction"
                            HorizontalAlignment="Center"
                            Command="{Binding Shell.LibraryBrowser.OpenCreateCollectionCommand}">
                      <StackPanel Orientation="Horizontal"
                                  Spacing="6"
                                  VerticalAlignment="Center">
                        <PathIcon Classes="AppIcon"
                                  Width="13"
                                  Height="13"
                                  VerticalAlignment="Center"
                                  Data="{StaticResource IconAddFolder}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="Create one" />
                      </StackPanel>
                    </Button>
                  </StackPanel>
                  <!-- MaxHeight: ~4 items at NavItem MinHeight 42px + 6px Margin each -->
                  <ScrollViewer Theme="{StaticResource OverlayScrollViewerTheme}"
                                MaxHeight="210"
                                AllowAutoHide="False"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Shell.LibraryBrowser.Collections}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:BookCollectionListItemViewModel">
                          <Button Classes="NavItem"
                                  Classes.Active="{Binding IsSelected}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,6"
                                  ContextRequested="OnCollectionItemContextRequested"
                                  Command="{Binding #MainWindowRoot.DataContext.Shell.LibraryBrowser.SelectCollectionCommand}"
                                  CommandParameter="{Binding .}"
                                  ToolTip.Tip="{Binding Name}">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="10">
                              <Border Classes="NavIconBadge">
                                <TextBlock Classes="NavIcon"
                                           Text="{Binding IconGlyph}" />
                              </Border>
                              <TextBlock Grid.Column="1"
                                         Classes="NavLabel"
                                         MaxWidth="132"
                                         VerticalAlignment="Center"
                                         Text="{Binding Name}"
                                         TextTrimming="CharacterEllipsis"
                                         TextWrapping="NoWrap" />
                            </Grid>
                          </Button>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                  <Border IsVisible="{Binding Shell.LibraryBrowser.HasCollections}"
                          Height="1"
                          Margin="0,0,0,0"
                          Background="{DynamicResource AppBorderBrush}" />
                  <Button Classes="CollectionAddAction"
                          IsVisible="{Binding Shell.LibraryBrowser.HasCollections}"
                          AutomationProperties.Name="Create collection"
                          Command="{Binding Shell.LibraryBrowser.OpenCreateCollectionCommand}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="7"
                                VerticalAlignment="Center">
                      <PathIcon Classes="AppIcon"
                                Width="13"
                                Height="13"
                                VerticalAlignment="Center"
                                Data="{StaticResource IconAddFolder}" />
                      <TextBlock VerticalAlignment="Center"
                                 Text="New collection" />
                    </StackPanel>
                  </Button>
                </StackPanel>
              </Border>
            </StackPanel>
          </StackPanel>

        </DockPanel>
      </Border>

      <!-- ── CONTENT AREA ────────────────────────────────── -->
      <!-- Background fill for content column -->
      <Border Grid.Column="1"
              Background="{DynamicResource AppSurfaceBrush}" />

      <Grid Grid.Column="1"
            DataContext="{Binding Shell}">
        <views:LibraryView IsVisible="{Binding IsLibrarySectionActive}" />
        <views:ImportView IsVisible="{Binding IsImportSectionActive}" />
        <views:SettingsView IsVisible="{Binding IsSettingsSectionActive}" />
      </Grid>

    </Grid>

    <Grid IsVisible="{Binding HasShell}">
      <Border IsVisible="{Binding Shell.LibraryBrowser.IsCreateCollectionDialogOpen}"
              Background="{DynamicResource AppDialogOverlayBrush}">
        <Border Classes="AppPanelCompact"
                Width="520"
                Padding="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel Spacing="16">
            <StackPanel Spacing="4">
              <TextBlock Classes="SectionEyebrow"
                         Text="COLLECTIONS" />
              <TextBlock Classes="SectionTitle"
                         Text="Create Collection" />
              <TextBlock Classes="BodyMuted"
                         Text="Choose a name and icon for the new collection." />
            </StackPanel>

            <TextBox Classes="AppTextInput"
                     PlaceholderText="Collection name"
                     Text="{Binding Shell.LibraryBrowser.NewCollectionName, Mode=TwoWay}" />

            <ListBox Classes="IconPickerGrid"
                     ItemsSource="{Binding Shell.LibraryBrowser.AvailableCollectionIcons}"
                     SelectedItem="{Binding Shell.LibraryBrowser.SelectedCreateCollectionIcon, Mode=TwoWay}">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="viewModels:BookCollectionIconOption">
                  <TextBlock FontSize="20"
                             LineHeight="28"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Text="{Binding Glyph}" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">
              <Button Classes="SecondaryAction"
                      Command="{Binding Shell.LibraryBrowser.CancelCreateCollectionCommand}"
                      Content="Cancel" />
              <Button Classes="PrimaryAction"
                      Command="{Binding Shell.LibraryBrowser.CreateCollectionCommand}"
                      Content="Create" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Border>

      <Border IsVisible="{Binding Shell.LibraryBrowser.IsDeleteCollectionDialogOpen}"
              Background="{DynamicResource AppDialogOverlayBrush}">
        <Border Classes="DangerPanel"
                Width="500"
                Padding="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel Spacing="16">
            <StackPanel Spacing="4">
              <TextBlock Classes="SectionEyebrow"
                         Text="COLLECTIONS" />
              <TextBlock Classes="SectionTitle"
                         Text="Delete Collection" />
              <TextBlock Classes="BodyMuted"
                         TextWrapping="Wrap">
                <Run Text="Delete '" />
                <Run Text="{Binding Shell.LibraryBrowser.PendingDeleteCollectionName}" />
                <Run Text="'? Books stay in the library; only collection membership is removed." />
              </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">
              <Button Classes="SecondaryAction"
                      Command="{Binding Shell.LibraryBrowser.CancelDeleteCollectionCommand}"
                      Content="Cancel" />
              <Button Classes="DestructiveAction"
                      Command="{Binding Shell.LibraryBrowser.ConfirmDeleteCollectionCommand}"
                      Content="Delete" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Border>
    </Grid>

  </Grid>
</Window>
