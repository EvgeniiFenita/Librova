<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Librova.UI.ViewModels"
             x:Class="Librova.UI.Views.SettingsView"
             x:DataType="viewModels:ShellViewModel"
             mc:Ignorable="d">

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16"
                Margin="20">

      <!-- Page header -->
      <StackPanel Spacing="4">
        <TextBlock Classes="SectionEyebrow"
                   Text="PREFERENCES" />
        <TextBlock Classes="ViewTitle"
                   Text="Settings" />
      </StackPanel>

      <!-- Converter settings -->
      <Border Classes="AccentPanel">
        <StackPanel Spacing="14">
          <StackPanel Spacing="2">
            <TextBlock Classes="SectionEyebrow"
                       Text="FB2 CONVERTER" />
            <TextBlock Classes="SectionTitle"
                       Text="Converter Executable" />
          </StackPanel>
          <TextBlock Classes="BodyMuted"
                     Text="Saving reloads the shell immediately with the new converter settings. Disable conversion to keep imported FB2 files as FB2 when fallback rules allow it."
                     TextWrapping="Wrap" />
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="10">
            <TextBox Classes="AppTextInput"
                     Watermark="C:\Tools\fbc.exe"
                     Text="{Binding Fb2CngExecutablePath}" />
            <Button Grid.Column="1"
                    Classes="SecondaryAction"
                    MinWidth="110"
                    Command="{Binding BrowseFb2CngExecutablePathCommand}"
                    Content="Browse..." />
          </Grid>
          <TextBlock FontSize="12"
                     Foreground="{DynamicResource AppWarningBrush}"
                     IsVisible="{Binding HasConverterValidationError}"
                     Text="{Binding ConverterValidationMessage}"
                     TextWrapping="Wrap" />
          <TextBlock Classes="Caption"
                     IsVisible="{Binding ShowConverterHelperText}"
                     Text="{Binding ConverterHintText}"
                     TextWrapping="Wrap" />
          <Button Classes="PrimaryAction"
                  Width="120"
                  HorizontalAlignment="Left"
                  Command="{Binding SavePreferencesCommand}"
                  Content="Save" />
        </StackPanel>
      </Border>

      <!-- About -->
      <Border Classes="AppPanelMuted">
        <StackPanel Spacing="12">
          <StackPanel Spacing="2">
            <TextBlock Classes="SectionEyebrow"
                       Text="ABOUT" />
            <TextBlock Classes="SectionTitle"
                       Text="Application" />
          </StackPanel>
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="16">
            <TextBlock Classes="MetaLabel"
                       VerticalAlignment="Center"
                       Text="VERSION" />
            <TextBlock Grid.Column="1"
                       Classes="BodyMuted"
                       Text="{Binding ApplicationVersionText}" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Diagnostics -->
      <Border Classes="AppPanelMuted">
        <StackPanel Spacing="14">
          <StackPanel Spacing="2">
            <TextBlock Classes="SectionEyebrow"
                       Text="DIAGNOSTICS" />
            <TextBlock Classes="SectionTitle"
                       Text="Runtime Paths" />
          </StackPanel>
          <TextBlock Classes="BodyMuted"
                     Text="{Binding DiagnosticsHintText}"
                     TextWrapping="Wrap" />
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="16"
                RowDefinitions="Auto,Auto,Auto,Auto"
                RowSpacing="10">
            <TextBlock Classes="MetaLabel"
                       VerticalAlignment="Top"
                       Text="UI LOG" />
            <TextBlock Grid.Column="1"
                       Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding UiLogFilePath}"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="1"
                       Classes="MetaLabel"
                       VerticalAlignment="Top"
                       Text="HOST LOG" />
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding HostLogFilePath}"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="2"
                       Classes="MetaLabel"
                       VerticalAlignment="Top"
                       Text="UI STATE" />
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding UiStateFilePath}"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="3"
                       Classes="MetaLabel"
                       VerticalAlignment="Top"
                       Text="PREFERENCES" />
            <TextBlock Grid.Row="3"
                       Grid.Column="1"
                       Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding UiPreferencesFilePath}"
                       TextWrapping="Wrap" />
          </Grid>

          <StackPanel Spacing="4">
            <TextBlock Classes="MetaLabel"
                       Text="HOST EXECUTABLE" />
            <TextBlock Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding HostExecutablePath}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>