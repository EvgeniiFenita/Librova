<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Librova.UI.ViewModels"
             x:Class="Librova.UI.Views.SettingsView"
             x:DataType="viewModels:ShellViewModel"
             mc:Ignorable="d">
  <StackPanel Spacing="18">
    <Border Classes="AppPanel">
      <StackPanel Spacing="12">
        <TextBlock Classes="SectionEyebrow"
                   Text="Preferences" />
        <TextBlock Classes="ViewTitle"
                   Text="Converter" />
        <TextBlock Classes="BodyMuted"
                   Text="Converter settings are applied on the next app launch. Disable conversion to keep imported FB2 files as FB2 when fallback rules allow it."
                   TextWrapping="Wrap" />

        <ComboBox Classes="AppComboBox"
                  SelectedItem="{Binding SelectedConverterMode}"
                  ItemsSource="{Binding AvailableConverterModes}" />

        <StackPanel IsVisible="{Binding IsBuiltInConverterSelected}"
                    Spacing="10">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="10">
            <TextBox Classes="AppTextInput"
                     Watermark="C:\Tools\fbc.exe"
                     Text="{Binding Fb2CngExecutablePath}" />
            <Button Grid.Column="1"
                    Classes="SecondaryAction"
                    MinWidth="108"
                    Command="{Binding BrowseFb2CngExecutablePathCommand}"
                    Content="Browse..." />
          </Grid>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsCustomConverterSelected}"
                    Spacing="10">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="10">
            <TextBox Classes="AppTextInput"
                     Watermark="C:\Tools\custom-converter.exe"
                     Text="{Binding CustomConverterExecutablePath}" />
            <Button Grid.Column="1"
                    Classes="SecondaryAction"
                    MinWidth="108"
                    Command="{Binding BrowseCustomConverterExecutablePathCommand}"
                    Content="Browse..." />
          </Grid>
          <ComboBox Classes="AppComboBox"
                    SelectedItem="{Binding SelectedCustomConverterOutputMode}"
                    ItemsSource="{Binding AvailableConverterOutputModes}" />
          <TextBox AcceptsReturn="True"
                   MinHeight="120"
                   TextWrapping="Wrap"
                   Classes="AppTextArea"
                   Watermark="One argument template per line, for example:&#10;--input&#10;{source}&#10;--output-dir&#10;{destination_dir}"
                   Text="{Binding CustomConverterArgumentsText}" />
        </StackPanel>

        <TextBlock FontSize="12"
                   Foreground="{DynamicResource AppWarningBrush}"
                   IsVisible="{Binding HasConverterValidationError}"
                   Text="{Binding ConverterValidationMessage}"
                   TextWrapping="Wrap" />
        <TextBlock Classes="Caption"
                   IsVisible="{Binding ShowConverterHelperText}"
                   Text="Built-in mode targets fb2cng. Custom mode expects the same placeholder-based argument contract used by the native converter runtime."
                   TextWrapping="Wrap" />
        <WrapPanel ItemWidth="138"
                   ItemHeight="42">
          <Button Classes="PrimaryAction"
                  Width="138"
                  Command="{Binding SavePreferencesCommand}"
                  Content="Save" />
        </WrapPanel>
      </StackPanel>
    </Border>

    <Border Classes="AppPanelMuted">
      <StackPanel Spacing="10">
        <TextBlock Classes="SectionEyebrow"
                   Text="Diagnostics" />
        <TextBlock Classes="SectionTitle"
                   Text="Runtime Paths" />
        <TextBlock Classes="BodyMuted"
                   Text="{Binding DiagnosticsHintText}"
                   TextWrapping="Wrap" />
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="10"
              RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock FontWeight="SemiBold"
                     Text="UI log" />
          <TextBlock Grid.Column="1"
                     Classes="BodyMuted"
                     Text="{Binding UiLogFilePath}"
                     TextWrapping="Wrap" />
          <TextBlock Grid.Row="1"
                     FontWeight="SemiBold"
                     Text="Host log" />
          <TextBlock Grid.Row="1"
                     Grid.Column="1"
                     Classes="BodyMuted"
                     Text="{Binding HostLogFilePath}"
                     TextWrapping="Wrap" />
          <TextBlock Grid.Row="2"
                     FontWeight="SemiBold"
                     Text="UI state" />
          <TextBlock Grid.Row="2"
                     Grid.Column="1"
                     Classes="BodyMuted"
                     Text="{Binding UiStateFilePath}"
                     TextWrapping="Wrap" />
          <TextBlock Grid.Row="3"
                     FontWeight="SemiBold"
                     Text="Preferences" />
          <TextBlock Grid.Row="3"
                     Grid.Column="1"
                     Classes="BodyMuted"
                     Text="{Binding UiPreferencesFilePath}"
                     TextWrapping="Wrap" />
        </Grid>
        <TextBlock FontWeight="SemiBold"
                   Text="Host executable" />
        <TextBlock Classes="BodyMuted"
                   Text="{Binding HostExecutablePath}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
