<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="using:Librova.UI.ViewModels"
             x:Class="Librova.UI.Views.SettingsView"
             x:DataType="viewModels:ShellViewModel"
             mc:Ignorable="d">
  <UserControl.Styles>
    <Style Selector="UserControl:visible">
      <Style.Animations>
        <Animation Duration="0:0:0.15" FillMode="None">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="16"
                Margin="20">

      <!-- Page header -->
      <StackPanel Spacing="4">
        <TextBlock Classes="SectionEyebrow"
                   Text="PREFERENCES" />
        <TextBlock Classes="ViewTitle"
                   Text="Settings" />
      </StackPanel>

      <!-- Converter settings -->
      <Border Classes="AccentPanel">
        <StackPanel Spacing="14">
          <StackPanel Spacing="2">
            <TextBlock Classes="SectionEyebrow"
                       Text="FB2 CONVERTER" />
            <TextBlock Classes="SectionTitle"
                       Text="Converter Executable" />
          </StackPanel>
          <TextBlock Classes="BodyMuted"
                     Text="Settings are applied automatically after validation. Use × to remove the configured converter and disable FB2 conversion."
                     TextWrapping="Wrap" />
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="8">
            <TextBox Classes="AppTextInput"
                     PlaceholderText="C:\Tools\fbc.exe"
                     Text="{Binding Fb2CngExecutablePath}" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
              <Button Classes="IconActionSm"
                      IsVisible="{Binding HasConfiguredConverter}"
                      Command="{Binding ClearConverterPathCommand}"
                      ToolTip.Tip="Remove converter">
                <PathIcon Data="{StaticResource IconClose}"
                          Width="14"
                          Height="14" />
              </Button>
              <Button Classes="SecondaryAction"
                      MinWidth="110"
                      Command="{Binding BrowseFb2CngExecutablePathCommand}"
                      Content="Browse..." />
            </StackPanel>
          </Grid>
          <TextBlock FontSize="12"
                     Foreground="{DynamicResource AppWarningBrush}"
                     IsVisible="{Binding HasConverterValidationError}"
                     Text="{Binding ConverterValidationMessage}"
                     TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal"
                      Spacing="8"
                      IsVisible="{Binding IsConverterConfiguredSuccessfully}">
            <PathIcon Data="{StaticResource IconCheck}"
                      Width="15"
                      Height="15"
                      Foreground="{DynamicResource AppSuccessBrush}"
                      VerticalAlignment="Center" />
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AppSuccessBrush}"
                       VerticalAlignment="Center"
                       Text="Converter configured successfully" />
          </StackPanel>
          <TextBlock Classes="Caption"
                     IsVisible="{Binding IsConverterProbeInProgress}"
                     Text="{Binding ConverterProbeStatusText}"
                     TextWrapping="Wrap" />
          <TextBlock Classes="Caption"
                     IsVisible="{Binding ShowConverterHelperText}"
                     Text="{Binding ConverterHintText}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- About -->
      <Border Classes="AppPanelCompact">
        <StackPanel Spacing="16">
          <StackPanel Spacing="8">
            <TextBlock Classes="SectionEyebrow"
                       Text="ABOUT" />
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <PathIcon Classes="AppIconAccent"
                        Data="{DynamicResource IconBook}"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Center" />
              <TextBlock Classes="SectionTitle"
                         VerticalAlignment="Center"
                         Text="Librova" />
            </StackPanel>
          </StackPanel>
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="20"
                RowDefinitions="Auto,Auto,Auto"
                RowSpacing="10">
            <TextBlock Classes="MetaLabel"
                       VerticalAlignment="Center"
                       Text="VERSION" />
            <TextBlock Grid.Column="1"
                       Classes="BodyMuted"
                       VerticalAlignment="Center"
                       Text="{Binding ApplicationVersionText}" />

            <TextBlock Grid.Row="1"
                       Classes="MetaLabel"
                       VerticalAlignment="Center"
                       Text="AUTHOR" />
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Classes="BodyMuted"
                       VerticalAlignment="Center"
                       Text="{Binding ApplicationAuthorText}" />

            <TextBlock Grid.Row="2"
                       Classes="MetaLabel"
                       VerticalAlignment="Center"
                       Text="CONTACT" />
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Classes="Caption"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding ApplicationContactEmailText}" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- Diagnostics -->
      <Border Classes="AppPanelMuted">
        <StackPanel Spacing="14">
          <StackPanel Spacing="2">
            <TextBlock Classes="SectionEyebrow"
                       Text="DIAGNOSTICS" />
            <TextBlock Classes="SectionTitle"
                       Text="Runtime Paths" />
          </StackPanel>
          <TextBlock Classes="BodyMuted"
                     Text="{Binding DiagnosticsHintText}"
                     TextWrapping="Wrap" />
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="16"
                RowDefinitions="Auto,Auto,Auto,Auto"
                RowSpacing="10">
            <TextBlock Classes="MetaLabel"
                       VerticalAlignment="Top"
                       Text="UI LOG" />
            <TextBlock Grid.Column="1"
                       Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding UiLogFilePath}"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="1"
                       Classes="MetaLabel"
                       VerticalAlignment="Top"
                       Text="HOST LOG" />
            <TextBlock Grid.Row="1"
                       Grid.Column="1"
                       Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding HostLogFilePath}"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="2"
                       Classes="MetaLabel"
                       VerticalAlignment="Top"
                       Text="UI STATE" />
            <TextBlock Grid.Row="2"
                       Grid.Column="1"
                       Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding UiStateFilePath}"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="3"
                       Classes="MetaLabel"
                       VerticalAlignment="Top"
                       Text="PREFERENCES" />
            <TextBlock Grid.Row="3"
                       Grid.Column="1"
                       Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding UiPreferencesFilePath}"
                       TextWrapping="Wrap" />
          </Grid>

          <StackPanel Spacing="4">
            <TextBlock Classes="MetaLabel"
                       Text="HOST EXECUTABLE" />
            <TextBlock Classes="Caption"
                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                       Text="{Binding HostExecutablePath}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>